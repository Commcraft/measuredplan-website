<?xml version="1.0" encoding="UTF-8"?>
<!--
  Alias so /sitemap.xml resolves (Google Search Console and most tools probe
  this path by default). It points at the Astro-generated sitemap-0.xml, which
  is regenerated on every build and stays current.
-->
<sitemapindex xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <sitemap>
    <loc>https://measuredplan.com/sitemap-0.xml</loc>
  </sitemap>
</sitemapindex>

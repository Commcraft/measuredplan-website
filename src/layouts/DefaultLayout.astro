---
import BaseHead from "@/components/BaseHead.astro";
import MobileCtaBar from "@/components/MobileCtaBar.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  jsonLd?: Record<string, unknown>[];
  noindex?: boolean;
}
const { title, description, image, jsonLd, noindex } = Astro.props;
---

<html lang="en-US">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      jsonLd={jsonLd}
      noindex={noindex}
    />
  </head>
  <body class="min-h-screen antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-sm focus:bg-ink focus:px-4 focus:py-2 focus:text-sm focus:text-paper"
      >Skip to content</a
    >
    <SiteHeader />
    <main id="main"><slot /></main>
    <SiteFooter />
    <MobileCtaBar />
  </body>
</html>

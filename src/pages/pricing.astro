---
import CTASection from "@/components/CTASection.astro";
import Faq from "@/components/Faq.astro";
import LinkButton from "@/components/LinkButton.astro";
import PageIntro from "@/components/PageIntro.astro";
import Section from "@/components/Section.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import DefaultLayout from "@/layouts/DefaultLayout.astro";
import { breadcrumbJsonLd, faqPageJsonLd } from "@/lib/seo";
import { SITE_URL } from "@/consts";

// Published starting prices. Ranges are typical, not caps; the final quote is
// confirmed once scope is known. Keep these in sync with the service pages.
const priceList = [
  {
    service: "On-site measuring & existing-conditions documentation",
    from: "$295",
    range: "$295-$950+",
    href: "/services/measured-building-surveys/",
  },
  {
    service: "As-built floor plans",
    from: "$395",
    range: "$395-$1,250+",
    href: "/services/measured-building-surveys/",
  },
  {
    service: "Permit-ready / construction drawings",
    from: "$795",
    range: "$795-$5,500+",
    href: "/services/construction-drawings/",
  },
  {
    service: "Site plans / plot plans",
    from: "$295",
    range: "$295-$450+",
    href: "/services/construction-drawings/",
  },
  {
    service: "Sketch / PDF to CAD conversion",
    from: "$225",
    range: "$225-$750+",
    href: "/services/cad-drafting/",
  },
  {
    service: "Commercial as-built & tenant improvement plans",
    from: "$950",
    range: "$950-$5,000+",
    href: "/services/measured-building-surveys/",
  },
  {
    service: "CAD drafting support for contractors",
    from: "$75/hr",
    range: "$75-$95/hr",
    href: "/services/cad-drafting/",
  },
  {
    service: "Concept design",
    from: "Priced individually",
    href: "/services/concept-design/",
  },
  {
    service: "HOA design & approval",
    from: "Priced individually",
    href: "/services/hoa-design-approval/",
  },
];

const factors = [
  {
    title: "Floor area & stories",
    body: "The size of the property and the number of levels to measure and draw.",
  },
  {
    title: "Building complexity",
    body: "Ornate, irregular or heavily subdivided buildings take longer to measure and draft.",
  },
  {
    title: "Access & occupancy",
    body: "Occupied properties, restricted access and travel distance all affect the fee.",
  },
  {
    title: "Outputs required",
    body: "Which drawings, scales and formats you need - from a single plan to a full set.",
  },
];

const included = [
  "A site visit and on-site measurement",
  "Layered DWG and scaled PDF",
  "A clear title block, scale bar and north point",
  "One revision against the recorded measurements",
];

const pricingFaqs = [
  {
    question: "Do you publish prices?",
    answer:
      "Yes. Starting prices are published for each service above. Your final quote depends on floor area, complexity, access and the outputs you need - confirmed before work starts.",
  },
  {
    question: "Is the quote fixed?",
    answer:
      "Your quote is held for the agreed scope. If the scope changes, any additional work is quoted separately before it starts. Design services such as construction drawings and concept design are scoped per project.",
  },
  {
    question: "What is rush turnaround?",
    answer:
      "When a project needs to jump the queue, rush turnaround is available for a surcharge of 25-35% of the project fee, confirmed at quote.",
  },
  {
    question: "Is sales tax included?",
    answer:
      "Quotes state clearly whether sales tax applies to your project, so the total is never a surprise.",
  },
  {
    question: "When is payment due?",
    answer:
      "Payment terms are set out on the quote and invoice, and confirmed before work starts.",
  },
];

const crumbs = [
  { label: "Home", href: "/" },
  { label: "Pricing", href: "/pricing/" },
];

// Structured data for the published starting prices.
const priceOffers = {
  "@context": "https://schema.org",
  "@type": "OfferCatalog",
  name: "MeasuredPlan services and starting prices",
  url: `${SITE_URL}/pricing/`,
  itemListElement: priceList
    .filter((p) => p.from.startsWith("$"))
    .map((p) => {
      const amount = Number(p.from.replace(/[^0-9.]/g, ""));
      const hourly = p.from.includes("/hr");
      return {
        "@type": "Offer",
        name: p.service,
        url: `${SITE_URL}${p.href ?? "/pricing/"}`,
        priceSpecification: hourly
          ? {
              "@type": "UnitPriceSpecification",
              priceCurrency: "USD",
              price: amount,
              unitCode: "HUR",
            }
          : {
              "@type": "PriceSpecification",
              priceCurrency: "USD",
              minPrice: amount,
            },
      };
    }),
};
---

<DefaultLayout
  title="Pricing · Western North Carolina"
  description="How MeasuredPlan pricing works: published starting prices by service, with the final quote based on floor area, complexity, access and the outputs required."
  jsonLd={[breadcrumbJsonLd(crumbs), faqPageJsonLd(pricingFaqs), priceOffers]}
>
  <PageIntro
    eyebrow="Pricing"
    title="Starting prices, by service."
    intro="Starting prices are published for each service below. Your final quote depends on the property and the drawings you need - scope and price are confirmed before any work begins."
    crumbs={crumbs}
  />

  <!-- Price list -->
  <Section surface="stone">
    <SectionHeading
      eyebrow="By service"
      title="What each service starts at."
      intro="Ranges are typical, not caps. Send the property details and we'll confirm a quote - usually within one business day."
    />
    <table class="mt-12 block w-full border border-line sm:table">
      <caption class="sr-only">
        MeasuredPlan starting prices by service
      </caption>
      <tbody class="block sm:table-row-group">
        {
          priceList.map((p, i) => (
            <tr
              class:list={[
                "block bg-white p-6 sm:table-row sm:p-0",
                i > 0 && "border-t border-line",
              ]}
            >
              <th
                scope="row"
                class="block text-left align-middle font-normal sm:table-cell sm:p-7"
              >
                <span class="block text-lg leading-snug text-ink">
                  {p.service}
                </span>
                {p.range && (
                  <span class="mt-1 block font-mono text-xs text-ink-muted">
                    Typical range {p.range}
                  </span>
                )}
              </th>
              <td class="mt-3 block align-middle sm:mt-0 sm:table-cell sm:p-7 sm:text-right">
                {p.from.startsWith("$") ? (
                  <>
                    <span class="block font-mono text-xs uppercase tracking-wide text-ink-muted">
                      Starting at
                    </span>
                    <span class="font-display text-xl font-semibold text-ink">
                      {p.from}
                    </span>
                  </>
                ) : (
                  <span class="font-mono text-sm text-ink-muted">{p.from}</span>
                )}
              </td>
              <td class="mt-4 block align-middle sm:mt-0 sm:table-cell sm:p-7 sm:text-right">
                {p.href && (
                  <LinkButton
                    href={p.href}
                    variant="outline"
                    size="sm"
                    class="justify-self-start sm:justify-self-end"
                  >
                    Details
                  </LinkButton>
                )}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
    <p class="mt-4 max-w-3xl text-base text-ink-muted">
      <span class="font-medium text-ink">Rush turnaround</span> is available for
      a surcharge of 25-35% of the project fee, confirmed at quote. Starting
      prices are a floor, not a fixed fee - the final scope and price are
      confirmed before work begins.
    </p>
  </Section>

  <!-- How the fee is calculated -->
  <Section surface="paper">
    <SectionHeading
      eyebrow="How the fee is calculated"
      title="Four things move the fee."
      intro="Tell us about these and we can confirm an accurate quote - usually within one business day."
    />
    <div class="mt-12 grid gap-x-10 gap-y-10 sm:grid-cols-2 lg:grid-cols-4">
      {
        factors.map((f, i) => (
          <div class="border-t border-line pt-5">
            <span class="font-mono text-sm text-ink-muted">
              {String(i + 1).padStart(2, "0")}
            </span>
            <h3 class="mt-3 text-lg leading-snug">{f.title}</h3>
            <p class="mt-2 text-[0.95rem] leading-relaxed text-ink-muted">
              {f.body}
            </p>
          </div>
        ))
      }
    </div>
  </Section>

  <!-- Always included -->
  <Section surface="cad">
    <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:gap-16">
      <SectionHeading eyebrow="Always included" title="What every quote covers." />
      <div>
        <ul class="grid gap-x-10 sm:grid-cols-2">
          {
            included.map((item) => (
              <li class="flex items-start gap-2.5 border-t border-line py-4 text-[0.95rem] text-ink">
                <span class="datum-tick mt-1.5" aria-hidden="true" />
                {item}
              </li>
            ))
          }
        </ul>
        <p class="mt-4 text-base text-ink-muted">
          Construction drawings and concept design typically involve more than
          one revision round; the revision scope is confirmed with the quote.
        </p>
      </div>
    </div>
  </Section>

  <!-- Pricing FAQ -->
  <Section surface="paper">
    <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:gap-16">
      <SectionHeading eyebrow="Questions" title="Pricing, payment and terms." />
      <div>
        <Faq items={pricingFaqs} />
        <div class="mt-8">
          <LinkButton href="/faq/" variant="ghost" size="sm">
            All questions →
          </LinkButton>
        </div>
      </div>
    </div>
  </Section>

  <CTASection
    title="Send your property details for a quote."
    secondaryLabel="See services"
    secondaryHref="/services/"
  />
</DefaultLayout>

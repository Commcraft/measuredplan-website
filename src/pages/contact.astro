---
import { getCollection } from "astro:content";

import Container from "@/components/Container.astro";
import Eyebrow from "@/components/Eyebrow.astro";
import LinkButton from "@/components/LinkButton.astro";
import PageIntro from "@/components/PageIntro.astro";
import WhatsAppLink from "@/components/WhatsAppLink.astro";
import {
  BUSINESS,
  CONTACT_FORM,
  CONTACT_FORM_CONFIGURED,
  SITE_URL,
} from "@/consts";
import DefaultLayout from "@/layouts/DefaultLayout.astro";
import { breadcrumbJsonLd } from "@/lib/seo";

const services = (await getCollection("services"))
  .filter((s) => !s.data.landingOnly)
  .sort((a, b) => a.data.order - b.data.order);

// One real client quote, placed beside the form as social proof at the point
// of decision. Kept factual - drawn from the testimonials collection.
const testimonials = (await getCollection("testimonials")).sort(
  (a, b) => a.data.order - b.data.order,
);
const proof = testimonials[0]?.data;

// Reassurance points shown above the form to lower submission anxiety.
const trust = [
  { label: "Reply within one business day", sub: "Usually the same day" },
  { label: "No-obligation quote", sub: "A clear price, no commitment" },
  { label: "Your details stay private", sub: "Used only to reply to you" },
];

// Track-record proof points. Real figures from the practice.
const stats = [
  { value: "8", accent: "+", label: "Years in the field" },
  { value: "500", accent: "+", label: "Projects completed" },
  { value: "72", accent: "hr", label: "Average turnaround" },
];

// Static-host contact backend (Web3Forms - free, no per-submission activation).
// When a valid access key is configured the form POSTs to Web3Forms, which
// emails BUSINESS.email and redirects to /contact/thanks/. Otherwise it falls
// back to composing an email in the visitor's mail app, so the contact route
// always works and no message is lost.
const formAction = CONTACT_FORM_CONFIGURED
  ? "https://api.web3forms.com/submit"
  : undefined;
const thanksUrl = `${SITE_URL}/contact/thanks/`;

const field =
  "w-full border border-line bg-white px-3.5 py-2.5 text-sm text-ink " +
  "placeholder:text-ink-muted focus-visible:outline-none focus-visible:border-ink " +
  "focus-visible:ring-1 focus-visible:ring-ink";
const labelCls = "block text-sm font-medium text-ink mb-2";

const crumbs = [
  { label: "Home", href: "/" },
  { label: "Contact", href: "/contact/" },
];
---

<DefaultLayout
  title="Request a Quote"
  description="Request a quote for as-built drawings or design work in Western North Carolina. Send your property details and we'll confirm scope, format and price."
  jsonLd={[breadcrumbJsonLd(crumbs)]}
>
  <PageIntro
    eyebrow="Contact"
    title="Request a quote."
    intro="Tell us about the property and what the drawings are for. We'll confirm the right drawing route, scope, format and a clear price - usually within one business day."
    crumbs={crumbs}
  />

  <!-- Track record: proof points at the point of decision. -->
  <section class="band-ink">
    <Container class="py-10 sm:py-12">
      <dl
        class="grid grid-cols-1 divide-y divide-line-inverse sm:grid-cols-3 sm:divide-x sm:divide-y-0"
      >
        {
          stats.map((s, i) => (
            <div
              class={`flex items-baseline gap-4 py-6 sm:flex-col sm:items-start sm:gap-3 sm:py-0 ${i === 0 ? "sm:pr-8" : "sm:px-8"}`}
            >
              <dt class="flex items-baseline gap-1">
                <span class="datum-tick self-center" aria-hidden="true" />
                <span class="font-display text-5xl font-semibold leading-none tracking-tight text-paper sm:text-6xl">
                  {s.value}
                </span>
                <span class="font-display text-2xl font-semibold leading-none text-red-inverse sm:text-3xl">
                  {s.accent}
                </span>
              </dt>
              <dd class="font-mono text-xs uppercase tracking-wider text-ink-muted-inverse">
                {s.label}
              </dd>
            </div>
          ))
        }
      </dl>
    </Container>
  </section>

  <section class="bg-paper py-14 sm:py-16">
    <Container>
      <div class="grid gap-12 lg:grid-cols-[1fr_1.5fr] lg:gap-16">
        <!-- Direct contact -->
        <aside class="lg:sticky lg:top-28 lg:h-fit">
          <Eyebrow class="mb-5">Direct contact</Eyebrow>
          <dl class="space-y-6">
            <div>
              <dt class="font-mono text-xs uppercase tracking-wider text-ink-muted">
                Email
              </dt>
              <dd class="mt-1.5">
                <a
                  href={`mailto:${BUSINESS.email}`}
                  class="text-ink underline-offset-4 hover:underline"
                  >{BUSINESS.email}</a
                >
              </dd>
            </div>
            <div>
              <dt class="font-mono text-xs uppercase tracking-wider text-ink-muted">
                Phone
              </dt>
              <dd class="mt-1.5">
                <a
                  href={`tel:${BUSINESS.phoneHref}`}
                  class="text-ink underline-offset-4 hover:underline"
                  >{BUSINESS.phone}</a
                >
              </dd>
            </div>
            <div>
              <dt class="font-mono text-xs uppercase tracking-wider text-ink-muted">
                WhatsApp
              </dt>
              <dd class="mt-2">
                <WhatsAppLink variant="solid" />
              </dd>
            </div>
            <div>
              <dt class="font-mono text-xs uppercase tracking-wider text-ink-muted">
                Hours
              </dt>
              <dd class="mt-1.5 text-ink">{BUSINESS.hours}</dd>
            </div>
            <div>
              <dt class="font-mono text-xs uppercase tracking-wider text-ink-muted">
                Coverage
              </dt>
              <dd class="mt-1.5 text-ink">{BUSINESS.areaServed}</dd>
            </div>
          </dl>

          <div class="mt-10 title-block p-5">
            <p class="text-base leading-relaxed text-ink-muted">
              Prefer to talk it through? A short call or WhatsApp message is
              often the quickest way to scope a project. Reach us during working
              hours, or send the form and we'll come back to you.
            </p>
          </div>

          {
            proof && (
              <figure class="mt-8 border-l-2 border-red pl-5">
                <blockquote class="text-base leading-relaxed text-ink">
                  &ldquo;{proof.quote}&rdquo;
                </blockquote>
                <figcaption class="mt-3 font-mono text-xs uppercase tracking-wider text-ink-muted">
                  {proof.name} - {proof.company}
                </figcaption>
              </figure>
            )
          }
        </aside>

        <!-- Quote form -->
        <div>
          {
            !CONTACT_FORM_CONFIGURED && (
              <div
                class="mb-8 flex items-start gap-3 border border-line surface-cad px-4 py-3.5"
                role="note"
              >
                <span
                  class="mt-1.5 h-1.5 w-1.5 shrink-0 bg-line-strong"
                  aria-hidden="true"
                />
                <p class="text-base leading-relaxed text-ink">
                  Submitting opens your email app with the details filled in. You
                  can also email
                  <a
                    href={`mailto:${BUSINESS.email}`}
                    class="underline underline-offset-4"
                  >
                    {BUSINESS.email}
                  </a>{" "}
                  or call {BUSINESS.phone} directly.
                </p>
              </div>
            )
          }

          <!-- Trust row: lowers submission anxiety at the point of decision. -->
          <ul class="mb-8 grid gap-3 sm:grid-cols-3">
            {
              trust.map((t) => (
                <li class="border-t-2 border-red pt-3">
                  <p class="text-sm font-medium leading-snug text-ink">
                    {t.label}
                  </p>
                  <p class="mt-1 text-xs text-ink-muted">{t.sub}</p>
                </li>
              ))
            }
          </ul>

          <form
            id="quote-form"
            class="space-y-6"
            data-email={BUSINESS.email}
            data-mode={CONTACT_FORM_CONFIGURED ? "backend" : "mailto"}
            action={formAction}
            method={CONTACT_FORM_CONFIGURED ? "POST" : undefined}
          >
            {
              CONTACT_FORM_CONFIGURED && (
                <>
                  {/* Web3Forms configuration fields */}
                  <input
                    type="hidden"
                    name="access_key"
                    value={CONTACT_FORM.web3formsKey}
                  />
                  <input
                    type="hidden"
                    name="subject"
                    value="New quote request - MeasuredPlan"
                  />
                  <input
                    type="hidden"
                    name="from_name"
                    value="MeasuredPlan website"
                  />
                  {/* No-JS fallback redirect (JS handles it on success). */}
                  <input type="hidden" name="redirect" value={thanksUrl} />
                  {/* Honeypot: bots tick this hidden box; humans never see it. */}
                  <input
                    type="checkbox"
                    name="botcheck"
                    class="hidden"
                    style="display:none"
                    tabindex="-1"
                    autocomplete="off"
                    aria-hidden="true"
                  />
                </>
              )
            }

            {/* Progress (JS only). Steps advance with commitment, so the form
                reads as a short conversation rather than one long wall. */}
            <div class="form-progress hidden">
              <div class="flex items-baseline justify-between">
                <span
                  class="font-mono text-xs uppercase tracking-wider text-ink-muted"
                  data-progress-label
                >
                  Step 1 of 4
                </span>
                <span class="font-mono text-xs text-ink-muted" data-progress-title>
                  What do you need?
                </span>
              </div>
              <div class="mt-2 h-0.5 w-full bg-line">
                <div
                  class="h-full bg-red transition-[width] duration-300"
                  style="width:25%"
                  data-progress-bar
                ></div>
              </div>
            </div>

            <p
              id="quote-status"
              class="hidden border border-line px-4 py-3 text-sm text-ink"
              role="status"
            >
            </p>

            {/* Step 1 - what they need (engaging, low friction, asked first). */}
            <div data-step="1" data-step-title="What do you need?" data-step-active>
              <fieldset>
                <legend class={labelCls}>Service needed</legend>
                <div class="grid gap-2.5 sm:grid-cols-2">
                  {
                    services.map((s) => (
                      <label class="flex items-center gap-3 border border-line bg-white px-3.5 py-2.5 text-sm text-ink transition-colors hover:border-line-strong has-[:checked]:border-ink has-[:checked]:bg-cad">
                        <input
                          type="checkbox"
                          name="service"
                          value={s.data.title}
                          class="size-4 accent-[color:var(--mp-ink)]"
                        />
                        {s.data.title}
                      </label>
                    ))
                  }
                </div>
              </fieldset>
              <div class="mt-6">
                <label for="property-type" class={labelCls}>Property type</label>
                <select id="property-type" name="property-type" class={field}>
                  <option value="">Select…</option>
                  <option>House</option>
                  <option>Apartment / condo</option>
                  <option>Commercial</option>
                  <option>Land / site</option>
                  <option>Other</option>
                </select>
              </div>
            </div>

            {/* Step 2 - the property. */}
            <div data-step="2" data-step-title="The property">
              <div>
                <label for="location" class={labelCls}>Property address / ZIP code</label>
                <input id="location" name="location" type="text" required class={field} autocomplete="street-address" />
              </div>
              <div class="mt-6 grid gap-6 sm:grid-cols-2">
                <div>
                  <label for="size" class={labelCls}>Approx. floor area or stories</label>
                  <input id="size" name="size" type="text" class={field} placeholder="e.g. 1,200 sq ft, or 2 stories" />
                </div>
                <div>
                  <label for="timeline" class={labelCls}>Preferred timeline</label>
                  <select id="timeline" name="timeline" class={field}>
                    <option value="">Select…</option>
                    <option>As soon as possible</option>
                    <option>Within a month</option>
                    <option>1-3 months</option>
                    <option>Flexible</option>
                  </select>
                </div>
              </div>
            </div>

            {/* Step 3 - details. */}
            <div data-step="3" data-step-title="The drawings">
              <label for="details" class={labelCls}>Project details</label>
              <textarea id="details" name="details" rows="5" required class={field} placeholder="What are the drawings for? Permitting, a lease, a renovation, a record…"></textarea>
              <p class="mt-4 text-base leading-relaxed text-ink-muted">
                Have existing drawings? Mention them here and we'll send a secure
                upload link when we reply.
              </p>
            </div>

            {/* Step 4 - contact details, asked last once they're invested. */}
            <div data-step="4" data-step-title="Where to reply">
              <div class="grid gap-6 sm:grid-cols-2">
                <div>
                  <label for="name" class={labelCls}>Name</label>
                  <input id="name" name="name" type="text" required class={field} autocomplete="name" />
                </div>
                <div>
                  <label for="email" class={labelCls}>Email</label>
                  <input id="email" name="email" type="email" required class={field} autocomplete="email" inputmode="email" />
                </div>
              </div>
              <div class="mt-6">
                <label for="phone" class={labelCls}>
                  Phone <span class="font-normal text-ink-muted">(optional, for a quicker reply)</span>
                </label>
                <input id="phone" name="phone" type="tel" class={field} autocomplete="tel" inputmode="tel" />
              </div>

              <div class="mt-8 flex flex-wrap items-center gap-4">
                <LinkButton type="submit" size="lg">Get my quote</LinkButton>
                <p class="text-sm text-ink-muted">
                  Free, no obligation. We'll reply with scope and a clear price,
                  usually within one business day.
                </p>
              </div>
            </div>

            {/* Step navigation (JS only; with JS off every step is visible and
                the single submit button above handles it). */}
            <div class="step-nav hidden items-center justify-between gap-4 pt-2">
              <button
                type="button"
                data-step-back
                class="font-mono text-sm text-ink-muted transition-colors hover:text-ink disabled:invisible"
              >
                ← Back
              </button>
              <LinkButton type="button" size="lg" data-step-next class="js-only">
                Continue
              </LinkButton>
            </div>
          </form>
        </div>
      </div>
    </Container>
  </section>
</DefaultLayout>

<script>
  const form = document.getElementById("quote-form") as HTMLFormElement | null;
  const status = document.getElementById("quote-status");

  function showStatus(message: string, isError = false) {
    if (!status) return;
    status.textContent = message;
    status.classList.remove("hidden");
    status.classList.toggle("border-red-deep", isError);
    status.classList.toggle("text-red-deep", isError);
  }

  // --- Multi-step wizard (progressive enhancement) ------------------------
  // Splits the long form into short, committing steps. Evidence: multi-step
  // forms of 5+ fields convert markedly better than one long wall because each
  // easy answer increases the visitor's investment. With JS off the CSS keeps
  // every step visible and this code never runs, so the form still works.
  function initWizard(f: HTMLFormElement) {
    const steps = Array.from(
      f.querySelectorAll<HTMLElement>("[data-step]"),
    );
    if (steps.length < 2) return null;

    // JS present: use our own step-by-step validation, not the native wall.
    f.noValidate = true;

    const label = f.querySelector<HTMLElement>("[data-progress-label]");
    const titleEl = f.querySelector<HTMLElement>("[data-progress-title]");
    const bar = f.querySelector<HTMLElement>("[data-progress-bar]");
    const backBtn = f.querySelector<HTMLButtonElement>("[data-step-back]");
    const nextBtn = f.querySelector<HTMLButtonElement>("[data-step-next]");
    const total = steps.length;
    let current = steps.findIndex((s) => s.hasAttribute("data-step-active"));
    if (current < 0) current = 0;

    function render() {
      steps.forEach((s, i) =>
        s.toggleAttribute("data-step-active", i === current),
      );
      if (label) label.textContent = `Step ${current + 1} of ${total}`;
      if (titleEl)
        titleEl.textContent = steps[current].dataset.stepTitle || "";
      if (bar) bar.style.width = `${((current + 1) / total) * 100}%`;
      if (backBtn) backBtn.disabled = current === 0;
      if (nextBtn)
        nextBtn.style.display = current === total - 1 ? "none" : "";
    }

    // Validate every field inside a given step; focus the first invalid one.
    function stepValid(i: number) {
      const fields = steps[i].querySelectorAll<
        HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement
      >("input, select, textarea");
      for (const field of fields) {
        if (!field.checkValidity()) {
          field.reportValidity();
          field.focus();
          return false;
        }
      }
      return true;
    }

    function goTo(i: number, focus = true) {
      current = Math.max(0, Math.min(total - 1, i));
      render();
      if (focus) {
        const first = steps[current].querySelector<HTMLElement>(
          "input:not([type=hidden]):not([type=checkbox]), select, textarea",
        );
        first?.focus({ preventScroll: true });
      }
      const top = f.getBoundingClientRect().top;
      if (top < 80) window.scrollBy({ top: top - 96, behavior: "smooth" });
    }

    nextBtn?.addEventListener("click", () => {
      if (stepValid(current)) goTo(current + 1);
    });
    backBtn?.addEventListener("click", () => goTo(current - 1));

    // Enter advances rather than submitting, except on the last step.
    f.addEventListener("keydown", (e) => {
      const t = e.target as HTMLElement;
      if (
        e.key === "Enter" &&
        t.tagName !== "TEXTAREA" &&
        current < total - 1
      ) {
        e.preventDefault();
        if (stepValid(current)) goTo(current + 1);
      }
    });

    render();
    // Jump to the first step that has an invalid field (used before submit).
    return {
      validateAll() {
        for (let i = 0; i < total; i++) {
          if (!stepValid(i)) {
            goTo(i);
            return false;
          }
        }
        return true;
      },
    };
  }

  const wizard = form ? initWizard(form) : null;

  // Compose the inquiry as an email in the visitor's mail app - the always-
  // available fallback so a message reaches us even if the backend is down or
  // not yet activated.
  function openMailto(f: HTMLFormElement) {
    const to = f.dataset.email || "";
    const data = new FormData(f);
    const val = (n: string) => (data.get(n) as string) || "";
    const services = data.getAll("service").join(", ");
    const lines = [
      `Name: ${val("name")}`,
      `Email: ${val("email")}`,
      `Phone: ${val("phone")}`,
      `Property / location: ${val("location")}`,
      `Service needed: ${services}`,
      `Property type: ${val("property-type")}`,
      `Approx. size: ${val("size")}`,
      `Timeline: ${val("timeline")}`,
      "",
      "Project details:",
      val("details"),
    ];
    const subject = `Quote request - ${val("name") || "MeasuredPlan"}`;
    window.location.href = `mailto:${to}?subject=${encodeURIComponent(
      subject,
    )}&body=${encodeURIComponent(lines.join("\n"))}`;
  }

  if (form && form.dataset.mode === "backend") {
    const f = form;
    const submitBtn = f.querySelector<HTMLButtonElement>('[type="submit"]');
    f.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (wizard && !wizard.validateAll()) return;
      submitBtn?.setAttribute("disabled", "");
      showStatus("Sending your request…");
      try {
        const res = await fetch(f.action, {
          method: "POST",
          headers: { Accept: "application/json" },
          body: new FormData(f),
        });
        const data = await res.json().catch(() => null);
        if (res.ok && data && String(data.success) === "true") {
          window.location.href = "/contact/thanks/";
          return;
        }
        throw new Error((data && data.message) || `HTTP ${res.status}`);
      } catch {
        // Backend unavailable or not yet activated: fall back to email so the
        // visitor's message still reaches us.
        submitBtn?.removeAttribute("disabled");
        showStatus(
          "Opening your email app so you can send this to us directly. If nothing happens, email " +
            (f.dataset.email || "") +
            ".",
          true,
        );
        openMailto(f);
      }
    });
  } else if (form) {
    const f = form;
    f.addEventListener("submit", (e) => {
      e.preventDefault();
      if (wizard && !wizard.validateAll()) return;
      showStatus(
        "Opening your email app… if nothing happens, email " +
          (f.dataset.email || "") +
          " directly.",
      );
      openMailto(f);
    });
  }
</script>

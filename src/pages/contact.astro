---
import { getCollection } from "astro:content";

import Container from "@/components/Container.astro";
import Eyebrow from "@/components/Eyebrow.astro";
import LinkButton from "@/components/LinkButton.astro";
import PageIntro from "@/components/PageIntro.astro";
import { BUSINESS } from "@/consts";
import DefaultLayout from "@/layouts/DefaultLayout.astro";
import { breadcrumbJsonLd } from "@/lib/seo";

const services = (await getCollection("services")).sort(
  (a, b) => a.data.order - b.data.order,
);

const field =
  "w-full border border-line bg-white px-3.5 py-2.5 text-sm text-ink " +
  "placeholder:text-ink-muted/70 focus-visible:outline-none focus-visible:border-ink " +
  "focus-visible:ring-1 focus-visible:ring-ink rounded-sm";
const labelCls = "block text-sm font-medium text-ink mb-2";

const crumbs = [
  { label: "Home", href: "/" },
  { label: "Contact", href: "/contact" },
];
---

<DefaultLayout
  title="Request a quote"
  description="Request a fixed-fee quote for a measured survey. Send your property details and what the drawings are for, and we'll confirm scope, format and price — usually within one working day."
  jsonLd={[breadcrumbJsonLd(crumbs)]}
>
  <PageIntro
    eyebrow="Contact"
    title="Request a quote."
    intro="Tell us about the property and what the drawings are for. We'll confirm the right drawing route, scope, format and a fixed fee — usually within one working day."
    crumbs={crumbs}
  />

  <section class="bg-paper py-14 sm:py-16">
    <Container>
      <div class="grid gap-12 lg:grid-cols-[1fr_1.5fr] lg:gap-16">
        <!-- Direct contact -->
        <aside class="lg:sticky lg:top-28 lg:h-fit">
          <Eyebrow class="mb-5">Direct contact</Eyebrow>
          <dl class="space-y-6">
            <div>
              <dt class="font-mono text-xs uppercase tracking-wider text-ink-muted">
                Email
              </dt>
              <dd class="mt-1.5">
                <a
                  href={`mailto:${BUSINESS.email}`}
                  class="text-ink underline-offset-4 hover:underline"
                  >{BUSINESS.email}</a
                >
              </dd>
            </div>
            <div>
              <dt class="font-mono text-xs uppercase tracking-wider text-ink-muted">
                Phone
              </dt>
              <dd class="mt-1.5">
                <a
                  href={`tel:${BUSINESS.phoneHref}`}
                  class="text-ink underline-offset-4 hover:underline"
                  >{BUSINESS.phone}</a
                >
              </dd>
            </div>
            <div>
              <dt class="font-mono text-xs uppercase tracking-wider text-ink-muted">
                Hours
              </dt>
              <dd class="mt-1.5 text-ink">{BUSINESS.hours}</dd>
            </div>
            <div>
              <dt class="font-mono text-xs uppercase tracking-wider text-ink-muted">
                Coverage
              </dt>
              <dd class="mt-1.5 text-ink">{BUSINESS.areaServed}</dd>
            </div>
          </dl>

          <div class="mt-10 title-block p-5">
            <p class="text-sm leading-relaxed text-ink-muted">
              Prefer to talk it through? A short call is often the quickest way
              to scope a survey. Call during working hours or send the form and
              we'll come back to you.
            </p>
          </div>
        </aside>

        <!-- Quote form -->
        <div>
          <!--
            The site is static (GitHub Pages), so the form has no server.
            Submitting composes an email in the visitor's mail app, addressed
            to BUSINESS.email, with the fields filled in. The email/phone above
            are always available as a direct fallback.
          -->
          <div
            class="mb-8 flex items-start gap-3 border border-line surface-cad px-4 py-3.5"
            role="note"
          >
            <span
              class="mt-1.5 h-1.5 w-1.5 shrink-0 bg-line-strong"
              aria-hidden="true"
            ></span>
            <p class="text-sm leading-relaxed text-ink">
              Submitting opens your email app with the details filled in. You can
              also email
              <a
                href={`mailto:${BUSINESS.email}`}
                class="underline underline-offset-4">{BUSINESS.email}</a
              > or call {BUSINESS.phone} directly.
            </p>
          </div>

          <form id="quote-form" data-email={BUSINESS.email} class="space-y-6">
            <p id="quote-status" class="hidden text-sm text-ink" role="status">
            </p>

            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label for="name" class={labelCls}>Name</label>
                <input id="name" name="name" type="text" required class={field} autocomplete="name" />
              </div>
              <div>
                <label for="email" class={labelCls}>Email</label>
                <input id="email" name="email" type="email" required class={field} autocomplete="email" />
              </div>
            </div>

            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label for="phone" class={labelCls}>
                  Phone <span class="font-normal text-ink-muted">(optional)</span>
                </label>
                <input id="phone" name="phone" type="tel" class={field} autocomplete="tel" />
              </div>
              <div>
                <label for="location" class={labelCls}>Property address / postcode</label>
                <input id="location" name="location" type="text" required class={field} />
              </div>
            </div>

            <fieldset>
              <legend class={labelCls}>Service needed</legend>
              <div class="grid gap-2.5 sm:grid-cols-2">
                {
                  services.map((s) => (
                    <label class="flex items-center gap-3 border border-line bg-white px-3.5 py-2.5 text-sm text-ink transition-colors hover:border-line-strong has-[:checked]:border-ink has-[:checked]:bg-cad">
                      <input
                        type="checkbox"
                        name="service"
                        value={s.data.title}
                        class="size-4 accent-[color:var(--mp-ink)]"
                      />
                      {s.data.title}
                    </label>
                  ))
                }
              </div>
            </fieldset>

            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label for="property-type" class={labelCls}>Property type</label>
                <select id="property-type" name="property-type" class={field}>
                  <option value="">Select…</option>
                  <option>House</option>
                  <option>Apartment / condo</option>
                  <option>Commercial</option>
                  <option>Land / site</option>
                  <option>Other</option>
                </select>
              </div>
              <div>
                <label for="size" class={labelCls}>Approx. floor area or stories</label>
                <input id="size" name="size" type="text" class={field} placeholder="e.g. 1,200 sq ft, or 2 stories" />
              </div>
            </div>

            <div>
              <label for="timeline" class={labelCls}>Preferred timeline</label>
              <select id="timeline" name="timeline" class={field}>
                <option value="">Select…</option>
                <option>As soon as possible</option>
                <option>Within a month</option>
                <option>1–3 months</option>
                <option>Flexible</option>
              </select>
            </div>

            <div>
              <label for="details" class={labelCls}>Project details</label>
              <textarea id="details" name="details" rows="5" required class={field} placeholder="What are the drawings for? Permitting, a lease, a renovation, a record…"></textarea>
            </div>

            <div>
              <label for="files" class={labelCls}>
                Existing files <span class="font-normal text-ink-muted">(optional)</span>
              </label>
              <textarea id="files" name="files" rows="2" class={field} placeholder="Do you have existing drawings? Tell us what and we'll send a secure upload link."></textarea>
            </div>

            <div class="flex flex-wrap items-center gap-4 pt-2">
              <LinkButton type="submit" size="lg">Send request</LinkButton>
              <p class="text-sm text-ink-muted">
                We'll reply with scope and a fixed fee, usually within one
                working day.
              </p>
            </div>
          </form>
        </div>
      </div>
    </Container>
  </section>
</DefaultLayout>

<script>
  // Static site: compose the enquiry as an email in the visitor's mail app.
  const form = document.getElementById("quote-form") as HTMLFormElement | null;
  const status = document.getElementById("quote-status");

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const to = form.dataset.email || "";
    const data = new FormData(form);
    const val = (n: string) => (data.get(n) as string) || "";
    const services = data.getAll("service").join(", ");

    const lines = [
      `Name: ${val("name")}`,
      `Email: ${val("email")}`,
      `Phone: ${val("phone")}`,
      `Property / location: ${val("location")}`,
      `Service needed: ${services}`,
      `Property type: ${val("property-type")}`,
      `Approx. size: ${val("size")}`,
      `Timeline: ${val("timeline")}`,
      "",
      "Project details:",
      val("details"),
      "",
      "Existing files:",
      val("files"),
    ];

    const subject = `Quote request — ${val("name") || "MeasuredPlan"}`;
    const href = `mailto:${to}?subject=${encodeURIComponent(
      subject,
    )}&body=${encodeURIComponent(lines.join("\n"))}`;

    if (status) {
      status.textContent =
        "Opening your email app… if nothing happens, email " + to + " directly.";
      status.classList.remove("hidden");
    }
    window.location.href = href;
  });
</script>

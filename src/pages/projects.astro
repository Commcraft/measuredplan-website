---
import { getCollection } from "astro:content";

import CTASection from "@/components/CTASection.astro";
import PageIntro from "@/components/PageIntro.astro";
import PlanThumb from "@/components/PlanThumb.astro";
import DefaultLayout from "@/layouts/DefaultLayout.astro";
import { breadcrumbJsonLd } from "@/lib/seo";
import { SITE_URL } from "@/consts";

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);
const services = (await getCollection("services")).sort(
  (a, b) => a.data.order - b.data.order,
);
const serviceName = (slug: string) =>
  services.find((s) => s.id === slug)?.data.title ?? slug;

const filters = [
  { id: "all", label: "All work" },
  ...services
    .filter((s) => !s.data.landingOnly)
    .map((s) => ({ id: s.id, label: s.data.title })),
];

const crumbs = [
  { label: "Home", href: "/" },
  { label: "Projects", href: "/projects/" },
];

// Structured data for search engines and AI answer engines: each project as a
// CreativeWork with its building type, location and the services it involved.
const projectsJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "MeasuredPlan projects",
  url: `${SITE_URL}/projects/`,
  about:
    "As-built drawings, construction drawings and design documentation across Western North Carolina",
  mainEntity: {
    "@type": "ItemList",
    itemListElement: projects.map((p, i) => ({
      "@type": "ListItem",
      position: i + 1,
      item: {
        "@type": "CreativeWork",
        name: p.data.title,
        about: p.data.buildingType,
        locationCreated: { "@type": "Place", name: p.data.location },
        dateCreated: p.data.date,
        image: `${SITE_URL}${p.data.image}`,
        creator: { "@id": `${SITE_URL}/#business` },
        keywords: p.data.service.map(serviceName).join(", "),
      },
    })),
  },
};
---

<DefaultLayout
  title="Sample Plans & Recent Projects"
  description="Sample as-built drawings - floor plans, elevations, sections and lease plans - showing the standard of MeasuredPlan's output across services."
  jsonLd={[breadcrumbJsonLd(crumbs), projectsJsonLd]}
>
  <PageIntro
    eyebrow="Selected work"
    title="Recent projects and drawing quality."
    intro="A selection of recent as-built drawings and documentation across residential and commercial projects. Filter by service to see the type of work we produce."
    crumbs={crumbs}
  />

  <section class="bg-paper pb-20 pt-10 sm:pb-24 sm:pt-12">
    <div class="container">
      <div class="surface-cad -mx-6 mb-10 border-y border-line px-6 py-3 sm:mx-0 sm:border sm:px-4">
        <p class="text-sm text-ink-muted">
          <span class="font-medium text-ink">Note:</span> a selection of recent
          as-built and drawing projects. Client names and property
          addresses have been removed.
        </p>
      </div>

      <div class="mb-10 flex flex-wrap gap-2" role="group" aria-label="Filter projects by service">
        {
          filters.map((f, i) => (
            <button
              type="button"
              data-filter={f.id}
              aria-pressed={i === 0 ? "true" : "false"}
              class="border border-line px-4 py-2 font-mono text-xs text-ink-muted transition-colors aria-pressed:border-ink aria-pressed:bg-ink aria-pressed:text-paper hover:text-ink"
            >
              {f.label}
            </button>
          ))
        }
      </div>

      <div
        id="project-grid"
        class="grid gap-6 pb-20 sm:grid-cols-2 lg:grid-cols-3"
      >
        {
          projects.map((p) => (
            <a
              href={`/projects/${p.id}/`}
              class="group flex flex-col"
              data-services={p.data.service.join(" ")}
              data-project
            >
              {p.data.image ? (
                <div class="title-block aspect-[4/3] overflow-hidden transition-colors group-hover:border-line-strong">
                  <img
                    src={p.data.image}
                    alt={`${p.data.title} - ${p.data.buildingType} in ${p.data.location} by MeasuredPlan`}
                    loading="lazy"
                    decoding="async"
                    class="h-full w-full bg-white object-cover object-top transition-transform duration-300 group-hover:scale-[1.03]"
                  />
                </div>
              ) : (
                <div class="transition-colors">
                  <PlanThumb variant={p.data.variant} label={p.data.title} />
                </div>
              )}
              <div class="mt-4">
                <span class="eyebrow">{p.data.buildingType}</span>
                <h2 class="mt-2 text-lg leading-snug transition-colors group-hover:text-red-deep">
                  {p.data.title}
                </h2>
                <p class="mt-1 font-mono text-xs text-ink-muted">
                  {p.data.location}
                </p>
                <p class="mt-2 text-base leading-relaxed text-ink-muted">
                  {p.data.scopeLine}
                </p>
                <ul class="mt-4 flex flex-wrap gap-2">
                  {p.data.service.map((s) => (
                    <li class="border border-line px-2.5 py-1 font-mono text-xs uppercase tracking-wide text-ink-muted">
                      {serviceName(s)}
                    </li>
                  ))}
                </ul>
              </div>
            </a>
          ))
        }
      </div>
      <p id="project-empty" class="hidden pb-20 text-ink-muted">
        No sample drawings for that service yet.
      </p>
    </div>
  </section>

  <CTASection />
</DefaultLayout>

<script>
  // Filter
  const buttons = document.querySelectorAll<HTMLButtonElement>("[data-filter]");
  const cards = document.querySelectorAll<HTMLElement>("[data-project]");
  const empty = document.getElementById("project-empty");

  buttons.forEach((btn) =>
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter!;
      buttons.forEach((b) =>
        b.setAttribute("aria-pressed", String(b === btn)),
      );
      let visible = 0;
      cards.forEach((card) => {
        const services = (card.dataset.services ?? "").split(" ");
        const show = filter === "all" || services.includes(filter);
        card.classList.toggle("hidden", !show);
        if (show) visible++;
      });
      empty?.classList.toggle("hidden", visible > 0);
    }),
  );
</script>

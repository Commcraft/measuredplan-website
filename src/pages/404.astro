---
import Container from "@/components/Container.astro";
import Eyebrow from "@/components/Eyebrow.astro";
import LinkButton from "@/components/LinkButton.astro";
import DefaultLayout from "@/layouts/DefaultLayout.astro";
---

<DefaultLayout
  title="Page not found"
  description="This page isn't on the plan. Find services, projects or get in touch."
  noindex={true}
>
  <section class="cad-grid-paper border-b border-line">
    <Container class="flex min-h-[62vh] flex-col items-center justify-center py-24 text-center">
      <Eyebrow class="mb-6 justify-center">Error 404</Eyebrow>
      <p class="font-mono text-sm text-ink-muted">/{Astro.url.pathname.slice(1)}</p>
      <h1 class="mt-4 text-4xl sm:text-5xl lg:text-6xl">
        This page isn't on the plan.
      </h1>
      <p class="mt-5 max-w-md text-lg text-ink-muted">
        The page may have moved or the address may be mistyped. Here are the
        useful routes back.
      </p>
      <div class="mt-9 flex flex-wrap justify-center gap-3">
        <LinkButton href="/" size="lg">Home</LinkButton>
        <LinkButton href="/services" variant="outline" size="lg">Services</LinkButton>
        <LinkButton href="/contact" variant="outline" size="lg">Contact</LinkButton>
      </div>
    </Container>
  </section>
</DefaultLayout>

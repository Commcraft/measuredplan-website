---
import type { GetStaticPaths } from "astro";
import { getCollection, render } from "astro:content";

import CTASection from "@/components/CTASection.astro";
import Eyebrow from "@/components/Eyebrow.astro";
import Faq from "@/components/Faq.astro";
import LinkButton from "@/components/LinkButton.astro";
import PageIntro from "@/components/PageIntro.astro";
import PlanThumb from "@/components/PlanThumb.astro";
import Section from "@/components/Section.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import SpecTable from "@/components/SpecTable.astro";
import DefaultLayout from "@/layouts/DefaultLayout.astro";
import { serviceJsonLd, faqPageJsonLd, breadcrumbJsonLd } from "@/lib/seo";

export const getStaticPaths = (async () => {
  const services = await getCollection("services");
  return services.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);

// Portfolio for this service: projects tagged with it first, then topped up
// with the newest work so every service page still shows (and links to) real
// projects even when nothing is tagged to it yet.
const allProjects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);
const tagged = allProjects.filter((p) => p.data.service.includes(entry.id));
const projects = [
  ...tagged,
  ...allProjects.filter((p) => !tagged.includes(p)),
].slice(0, 3);
const projectsHeading = tagged.length
  ? "Drawings of this type."
  : "Recent work from the practice.";

// "Choose this if" line, with the leading phrase stripped so it reads cleanly
// under the callout label.
const chooseThisIf = d.chooseThisIf
  ? (() => {
      const s = d.chooseThisIf.replace(/^choose this if\s+/i, "");
      return s.charAt(0).toUpperCase() + s.slice(1);
    })()
  : undefined;

// Cross-sell: resolve related service slugs to entries for the strip.
const allServices = await getCollection("services");
const related = d.related
  .map((slug) => allServices.find((s) => s.id === slug))
  .filter((s): s is NonNullable<typeof s> => Boolean(s))
  .slice(0, 3);

const specRows = [
  { label: "Accuracy", value: d.spec.accuracy },
  { label: "Scales", value: d.spec.scales },
  { label: "Formats", value: d.spec.formats },
  { label: "Method", value: d.spec.method },
];

const crumbs = [
  { label: "Home", href: "/" },
  { label: "Services", href: "/services/" },
  { label: d.title, href: `/services/${entry.id}/` },
];
---

<DefaultLayout
  title={d.seoTitle}
  description={d.seoDescription}
  jsonLd={[
    breadcrumbJsonLd(crumbs),
    serviceJsonLd({
      name: d.title,
      description: d.summary,
      slug: entry.id,
      fromFee: d.fromFee,
    }),
    faqPageJsonLd(d.faqs),
  ]}
>
  <PageIntro
    eyebrow={d.eyebrow}
    title={d.title}
    intro={d.intro}
    crumbs={crumbs}
  />

  <!-- Overview + who it's for -->
  <Section surface="paper">
    <div class="grid gap-12 lg:grid-cols-[1.3fr_1fr] lg:items-center lg:gap-16">
      <div class="order-2 lg:order-1 prose-tech max-w-none text-[1.05rem] leading-relaxed text-ink-muted [&>p]:mt-5 [&>p:first-child]:mt-0">
        <Content />
      </div>
      <!-- Summary + price + CTA. On mobile it leads (order-1) so a high-intent
           visitor sees who it's for, the fee and how to start before the prose. -->
      <aside class="order-1 lg:order-2 title-block h-fit p-6 sm:p-7">
        {
          chooseThisIf && (
            <div class="mb-6 border-l-2 border-red pl-4">
              <Eyebrow class="mb-2">Choose this if</Eyebrow>
              <p class="text-[0.95rem] leading-relaxed text-ink">
                {chooseThisIf}
              </p>
            </div>
          )
        }
        <Eyebrow class="mb-4">Who it's for</Eyebrow>
        <ul class="space-y-3">
          {
            d.forWho.map((who) => (
              <li class="flex items-start gap-3 text-sm text-ink">
                <span
                  class="mt-1.5 h-1 w-1 shrink-0 bg-line-strong"
                  aria-hidden="true"
                />
                {who}
              </li>
            ))
          }
        </ul>

        {/* Price + action surfaced early, so the buyer does not have to scroll
            the whole page to see the cost or how to start. */}
        <div class="mt-6 border-t border-line pt-6">
          <p class="font-mono text-xs uppercase tracking-wider text-ink-muted">
            Fee
          </p>
          <p class="mt-1 font-display text-2xl font-semibold text-ink">
            {d.fromFee}
          </p>
          <LinkButton
            href="/contact/"
            size="md"
            class="mt-4 w-full justify-center"
          >
            Get my quote
          </LinkButton>
          <p class="mt-2 text-xs text-ink-muted">
            Free, no obligation. Reply usually within one business day.
          </p>
        </div>
      </aside>
    </div>
  </Section>

  <!-- What's included + typical inputs -->
  <Section surface="stone">
    <div class="grid gap-10 md:grid-cols-2 lg:gap-16">
      <div>
        <SectionHeading eyebrow="What's included" title="Deliverables" as="h2" />
        <ul class="mt-8 divide-y divide-line border-y border-line">
          {
            d.included.map((item) => (
              <li class="flex items-start gap-2.5 py-3.5 text-[0.95rem] text-ink">
                <span
                  class="mt-2 h-1 w-1 shrink-0 bg-line-strong"
                  aria-hidden="true"
                />
                {item}
              </li>
            ))
          }
        </ul>
        <ul class="mt-6 flex flex-wrap gap-2">
          {
            d.deliverables.map((f) => (
              <li class="border border-line bg-white px-3 py-1 font-mono text-xs text-ink-muted">
                {f}
              </li>
            ))
          }
        </ul>
      </div>
      <div>
        <SectionHeading eyebrow="Typical inputs" title="What we need" as="h2" />
        <ul class="mt-8 space-y-4">
          {
            d.typicalInputs.map((item, i) => (
              <li class="flex items-start gap-4">
                <span class="font-mono text-sm text-ink-muted">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <span class="text-[0.95rem] leading-relaxed text-ink">
                  {item}
                </span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </Section>

  <!-- Sample sheets -->
  {
    d.samples.length > 0 && (
      <Section surface="paper">
        <SectionHeading
          eyebrow="Sample sheets"
          title="A sense of the output."
          intro="Recent work for this service. Client names and property addresses have been removed."
        />
        <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {d.samples.map((s, i) => (
            <figure>
              {s.image ? (
                <div class="title-block aspect-[4/3] overflow-hidden">
                  <img
                    src={s.image}
                    alt={s.caption}
                    loading="lazy"
            decoding="async"
                    class="h-full w-full bg-white object-cover object-top"
                  />
                </div>
              ) : (
                <PlanThumb variant={s.variant} label={s.caption} datum={i === 0} />
              )}
              <figcaption class="mt-3 font-mono text-xs text-ink-muted">
                {s.caption}
              </figcaption>
            </figure>
          ))}
        </div>
      </Section>
    )
  }

  <!-- Specification -->
  <Section surface="cad">
    <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:gap-16">
      <SectionHeading
        eyebrow="Specification"
        title="How the work is measured and delivered."
      />
      <SpecTable rows={specRows} />
    </div>
  </Section>

  <!-- Use cases -->
  <Section surface="paper">
    <SectionHeading eyebrow="Use cases" title="Where this service fits." />
    <div class="mt-12 grid gap-x-10 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
      {
        d.useCases.map((u) => (
          <div class="relative border-t border-line pt-6">
            <span
              class="absolute left-0 top-[-1px] h-[3px] w-8 bg-line-strong"
              aria-hidden="true"
            />
            <h3 class="text-lg leading-snug">{u.title}</h3>
            <p class="mt-2.5 text-[0.95rem] leading-relaxed text-ink-muted">
              {u.body}
            </p>
          </div>
        ))
      }
    </div>
  </Section>

  <!-- Fees -->
  <Section surface="paper">
    <div
      class="title-block grid gap-8 p-8 sm:p-10 lg:grid-cols-[1fr_1fr] lg:items-center"
    >
      <div>
        <Eyebrow class="mb-4">Fees</Eyebrow>
        <p class="font-display text-3xl font-semibold text-ink sm:text-4xl">
          {d.fromFee}
        </p>
        <p class="mt-3 max-w-md text-ink-muted">
          Every project is quoted individually. Three things move the fee:
        </p>
        <ul class="mt-5 space-y-3">
          {
            d.feeFactors.map((f, i) => (
              <li class="flex items-baseline gap-3 border-t border-line pt-3 text-sm text-ink">
                <span class="font-mono text-xs tabular-nums text-ink-muted">
                  {String(i + 1).padStart(2, "0")}
                </span>
                {f}
              </li>
            ))
          }
        </ul>
      </div>
      <div class="lg:justify-self-end">
        <LinkButton href="/contact/" size="lg">Get my quote</LinkButton>
        <p class="mt-3 text-sm text-ink-muted">
          Usually confirmed within one business day.
        </p>
      </div>
    </div>
  </Section>

  <!-- Service FAQ -->
  {
    d.faqs.length > 0 && (
      <Section surface="cad">
        <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:gap-16">
          <SectionHeading eyebrow="Questions" title={`About ${d.title}.`} />
          <Faq items={d.faqs} />
        </div>
      </Section>
    )
  }

  <!-- Related projects -->
  {
    projects.length > 0 && (
      <Section surface="paper">
        <div class="flex items-end justify-between gap-6">
          <SectionHeading eyebrow="Related work" title={projectsHeading} />
          <LinkButton href="/projects/" variant="outline" size="sm" class="shrink-0">
            All work
          </LinkButton>
        </div>
        <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {projects.map((p) => (
            <a href={`/projects/${p.id}/`} class="group flex flex-col">
              {p.data.image ? (
                <div class="title-block aspect-[4/3] overflow-hidden transition-colors group-hover:border-line-strong">
                  <img
                    src={p.data.image}
                    alt={`${p.data.title} - ${p.data.buildingType} in ${p.data.location}`}
                    loading="lazy"
                    decoding="async"
                    class="h-full w-full bg-white object-cover object-top transition-transform duration-300 group-hover:scale-[1.03]"
                  />
                </div>
              ) : (
                <PlanThumb variant={p.data.variant} label={p.data.title} />
              )}
              <div class="mt-4">
                <span class="eyebrow">{p.data.buildingType}</span>
                <h3 class="mt-2 text-lg leading-snug transition-colors group-hover:text-red-deep">
                  {p.data.title}
                </h3>
                <p class="mt-1 font-mono text-xs text-ink-muted">{p.data.location}</p>
                <p class="mt-2 text-sm text-ink-muted">{p.data.scopeLine}</p>
              </div>
            </a>
          ))}
        </div>
      </Section>
    )
  }

  <!-- You might also need -->
  {
    related.length > 0 && (
      <Section surface="stone">
        <SectionHeading eyebrow="You might also need" title="Pairs well with." />
        <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {related.map((s) => (
            <a
              href={`/services/${s.id}/`}
              class="title-block group flex flex-col bg-white p-6 transition-colors hover:border-line-strong"
            >
              <span class="eyebrow">{s.data.eyebrow}</span>
              <h3 class="mt-3 text-lg leading-snug transition-colors group-hover:text-red-deep">
                {s.data.title}
              </h3>
              <p class="mt-2 flex-1 text-base leading-relaxed text-ink-muted">
                {s.data.summary}
              </p>
              <span class="mt-5 flex items-center gap-2 border-t border-line pt-4 text-sm font-medium text-ink">
                View service
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  aria-hidden="true"
                  class="transition-transform duration-150 group-hover:translate-x-1"
                >
                  <path
                    d="M5 12h14M13 6l6 6-6 6"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
            </a>
          ))}
        </div>
      </Section>
    )
  }

  <nav class="border-t border-line bg-paper" aria-label="Service page">
    <div class="container flex flex-col sm:flex-row sm:items-stretch">
      <a
        href="/services/"
        class="group flex items-center gap-2 py-5 font-mono text-sm text-ink-muted transition-colors hover:text-ink"
      >
        <span
          aria-hidden="true"
          class="transition-transform duration-150 group-hover:-translate-x-0.5"
          >←</span
        >
        All services
      </a>
      <a
        href="/contact/"
        class="group flex items-center gap-2 border-t border-line py-5 font-mono text-sm text-ink-muted transition-colors hover:text-ink sm:ml-auto sm:border-t-0"
      >
        Get my quote
        <span
          aria-hidden="true"
          class="transition-transform duration-150 group-hover:translate-x-0.5"
          >→</span
        >
      </a>
    </div>
  </nav>

  <CTASection />
</DefaultLayout>

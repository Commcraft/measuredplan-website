---
import { getCollection } from "astro:content";

import CTASection from "@/components/CTASection.astro";
import Eyebrow from "@/components/Eyebrow.astro";
import LinkButton from "@/components/LinkButton.astro";
import PageIntro from "@/components/PageIntro.astro";
import ProcessStrip from "@/components/ProcessStrip.astro";
import Section from "@/components/Section.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import ServiceCard from "@/components/ServiceCard.astro";
import DefaultLayout from "@/layouts/DefaultLayout.astro";
import { breadcrumbJsonLd } from "@/lib/seo";

const allServices = (await getCollection("services")).sort(
  (a, b) => a.data.order - b.data.order,
);
const services = allServices.filter((s) => !s.data.landingOnly);
const landingServices = allServices.filter((s) => s.data.landingOnly);

const process = [
  { title: "Inquiry", body: "Tell us the property and what the drawings are for." },
  { title: "Site visit", body: "We measure on site to a stated datum." },
  { title: "Drawing", body: "We draft in CAD and check against the recorded measurements." },
  { title: "Delivery", body: "A clean, scaled set in your chosen formats." },
];

const crumbs = [
  { label: "Home", href: "/" },
  { label: "Services", href: "/services/" },
];
---

<DefaultLayout
  title="As-Built & Drafting Services · Western North Carolina"
  description="Drafting and documentation services: as-built documentation, construction drawings, concept design, lease plans, CAD drafting, 3D laser scanning and HOA design - delivered as clean, usable drawings."
  jsonLd={[breadcrumbJsonLd(crumbs)]}
>
  <PageIntro
    eyebrow="Services"
    title="Drafting and documentation, for design, permitting and building."
    intro="Whatever the property and whatever the drawings are for, the aim is the same: an accurate record, drawn clearly and delivered in a format you can use."
    crumbs={crumbs}
  />

  <Section surface="paper">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.map((s, i) => (
          <ServiceCard
            index={i}
            href={`/services/${s.id}/`}
            title={s.data.title}
            eyebrow={s.data.eyebrow}
            summary={s.data.summary}
            deliverables={s.data.deliverables.slice(0, 3)}
            optional={s.data.optional}
          />
        ))
      }
    </div>

    {
      landingServices.length > 0 && (
        <div class="mt-12 border-t border-line pt-8">
          <Eyebrow class="mb-5">Specialized routes</Eyebrow>
          <div class="grid gap-x-8 gap-y-4 sm:grid-cols-2">
            {landingServices.map((s) => (
              <a
                href={`/services/${s.id}/`}
                class="group flex items-start justify-between gap-4 border-b border-line py-3"
              >
                <span>
                  <span class="font-medium text-ink transition-colors group-hover:text-red-deep">
                    {s.data.title}
                  </span>
                  <span class="mt-0.5 block text-sm text-ink-muted">
                    {s.data.summary}
                  </span>
                </span>
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  aria-hidden="true"
                  class="mt-1 shrink-0 text-ink-muted transition-transform duration-150 group-hover:translate-x-1"
                >
                  <path
                    d="M5 12h14M13 6l6 6-6 6"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </a>
            ))}
          </div>
        </div>
      )
    }
  </Section>

  <!-- Not sure which service you need? -->
  <Section surface="stone">
    <div
      class="title-block grid gap-6 p-8 sm:p-10 lg:grid-cols-[1.3fr_1fr] lg:items-center"
    >
      <div>
        <Eyebrow class="mb-4">Not sure which plan you need?</Eyebrow>
        <h2 class="text-2xl leading-snug sm:text-3xl">
          Describe the property and the purpose - we will confirm the right
          drawing route.
        </h2>
        <p class="mt-4 max-w-xl text-ink-muted">
          Permitting, a lease, a renovation or a record: the right service and
          scale depend on what the drawings are for. Send the details and we will
          recommend the correct scope before you commit.
        </p>
      </div>
      <div class="flex flex-wrap gap-3 lg:justify-end">
        <LinkButton href="/contact/" size="md">Request a quote</LinkButton>
      </div>
    </div>
  </Section>

  <!-- Process summary -->
  <Section surface="paper">
    <SectionHeading
      eyebrow="Process"
      title="The same clear route, whichever service you need."
    />
    <ProcessStrip steps={process} class="mt-10" />
  </Section>

  <CTASection />
</DefaultLayout>

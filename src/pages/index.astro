      <LinkButton href="/projects/" variant="outline" size="sm" class="shrink-0">
        View all
      </LinkButton>
    </div>
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {
        projects.map((p) => (
          <a
            href={`/projects/${p.id}/`}
            class="title-block group flex flex-col overflow-hidden transition-[transform,box-shadow,border-color] duration-200 ease-out hover:-translate-y-1 hover:border-line-strong hover:shadow-lg"

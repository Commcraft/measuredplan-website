    </div>
    <p class="mt-6 max-w-2xl text-sm text-ink-muted">
      Recent project work. Client names and property addresses have been removed.
    </p>
  </Section>

  <!-- ===== Process ===== -->
  <Section surface="paper" labelledby="process-heading">
    <SectionHeading
      id="process-heading"
      eyebrow="Process"
      title="A clear route from inquiry to delivery."
      intro="Four steps, every project. You always know what happens next and what you will receive."

---
import { getCollection } from "astro:content";

import Container from "@/components/Container.astro";
import CTASection from "@/components/CTASection.astro";
import Eyebrow from "@/components/Eyebrow.astro";
import Faq from "@/components/Faq.astro";
import HeroField from "@/components/HeroField.astro";
import LinkButton from "@/components/LinkButton.astro";
import PlanThumb from "@/components/PlanThumb.astro";
import ProcessStrip from "@/components/ProcessStrip.astro";
import ProofPoint from "@/components/ProofPoint.astro";
import ProofStats from "@/components/ProofStats.astro";
import RouteFinder from "@/components/RouteFinder.astro";
import Section from "@/components/Section.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import ServiceCard from "@/components/ServiceCard.astro";
import Testimonials from "@/components/Testimonials.astro";
import { SITE_TAGLINE, BUSINESS } from "@/consts";
import DefaultLayout from "@/layouts/DefaultLayout.astro";
import { faqPageJsonLd } from "@/lib/seo";

const services = (await getCollection("services"))
  .filter((s) => !s.data.landingOnly)
  .sort((a, b) => a.data.order - b.data.order);
const projects = (await getCollection("projects"))
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const testimonials = (await getCollection("testimonials"))
  .sort((a, b) => a.data.order - b.data.order)
  .map((t) => t.data);

const allFaqs = (await getCollection("faqs")).sort(
  (a, b) => a.data.order - b.data.order,
);
const homeFaqs = allFaqs
  .filter((f) => f.data.services.length === 0)
  .slice(0, 5)
  .map((f) => ({ question: f.data.question, answer: f.data.answer }));

const process = [
  {
    title: "Inquiry",
    body: "Send the property details and what the drawings are for. We confirm scope, format and a clear price.",
  },
  {
    title: "Site visit",
    body: "We measure on site, recording the building or site accurately to a stated datum.",
  },
  {
    title: "Drawing",
    body: "We draft in CAD to a consistent layer structure, checked against the recorded measurements.",
  },
  {
    title: "Delivery",
    body: "You receive a clean, scaled set in the agreed formats, with a revision included.",
  },
];

const trust = [
  "On-site measurement",
  "Layered CAD output",
  `${BUSINESS.formats.join(" · ")} delivery`,
  "Starting-price quotes",
];

// Hero crossfade: shows the deliverables for the most-requested services, in
// priority order - an as-built floor plan (the #1 service), then a 3D model,
// then a design visualization. Leads with what visitors actually search for
// (accurate floor plans/drawings), not a niche render. First frame is
// eager/high-priority; the rest lazy. Reduced motion holds the first frame.
const heroSlides = [
  {
    src: "/projects/custom-home-mills-river.webp",
    alt: "An as-built floor plan drawn from an on-site MeasuredPlan measure",
  },
  {
    src: "/projects/luxury-home-3d.webp",
    alt: "A 3D model produced from an as-built measure",
  },
  {
    src: "/projects/hoa-mountain-home-landrum.webp",
    alt: "A design visualization developed from measured drawings",
  },
];

const proof = [
  {
    stat: "PDF · DWG · IFC",
    label: "Delivered in usable formats",
    note: "Layered AutoCAD DWG and scaled PDF as standard, IFC where a model is needed.",
  },
  {
    stat: "Revisions",
    label: "Built into the process",
    note: "Drawings are checked before issue; corrections against the recorded measurements are included.",
  },
  {
    stat: "Clear pricing",
    label: "Confirmed before we start",
    note: "Starting prices published by service; the final scope and price are confirmed before work begins.",
  },
  {
    stat: "Western NC",
    label: "Based locally",
    note: "On-site work across the region, without the travel markup of an out-of-town firm.",
  },
];
---

<DefaultLayout jsonLd={[faqPageJsonLd(homeFaqs)]}>
  <!-- ===== Hero ===== -->
  <section class="relative overflow-hidden border-b border-line bg-paper">
    <HeroField />
    <Container class="relative z-10 grid gap-10 py-9 sm:py-14 lg:grid-cols-[1.05fr_1fr] lg:items-center lg:gap-16 lg:py-24">
      <div>
        <Eyebrow class="mb-4 sm:mb-6">As-built & design drafting · Western North Carolina</Eyebrow>
        <h1 class="text-[2.3rem] leading-[1.05] sm:text-5xl lg:text-[3.5rem]">
          Accurate drawings of any building<span class="title-dot" aria-hidden="true"></span>
        </h1>
        <p class="mt-4 max-w-xl text-lg leading-relaxed text-ink-muted sm:mt-6">
          As-built, construction and concept drawings - to sell, lease, permit,
          renovate or build. Drawn to ANSI, NCREC and local standards for
          property owners, real estate and contractors across Western North
          Carolina.
        </p>
        <div class="mt-6 flex flex-wrap gap-3 sm:mt-9">
          <LinkButton href="/contact/" size="lg">Get my quote</LinkButton>
          <LinkButton href="/projects/" variant="outline" size="lg">
            View sample plans
          </LinkButton>
        </div>
        <ul class="mt-7 flex flex-wrap gap-x-6 gap-y-3 sm:mt-10">
          {
            trust.map((item) => (
              <li class="flex items-center gap-2 font-mono text-xs text-ink-muted">
                <span class="h-1 w-1 bg-line-strong" aria-hidden="true" />
                {item}
              </li>
            ))
          }
        </ul>
      </div>
      <figure class="relative">
        <div class="title-block overflow-hidden shadow-lg">
          <div class="relative aspect-[1200/758] bg-white">
            {/* Premium crossfade of real 3D models produced from as-built
                measures. All frames crop to one aspect via object-cover; the
                first is eager + high priority, the rest lazy. A tiny inline
                script cycles them; reduced motion holds the first frame. */}
            <div class="hero-slides absolute inset-0" data-hero-slides>
              {
                heroSlides.map((slide, i) => (
                  <img
                    src={slide.src}
                    alt={slide.alt}
                    width="1200"
                    height="758"
                    fetchpriority={i === 0 ? "high" : undefined}
                    loading={i === 0 ? "eager" : "lazy"}
                    decoding="async"
                    data-hero-slide
                    class:list={[
                      "hero-slide absolute inset-0 h-full w-full bg-white object-cover transition-opacity duration-[1100ms] ease-out",
                      i === 0 ? "opacity-100" : "opacity-0",
                    ]}
                    aria-hidden={i === 0 ? undefined : "true"}
                  />
                ))
              }
            </div>
          </div>
          <figcaption
            class="flex items-center gap-2.5 border-t border-line bg-white px-4 py-2.5 font-mono text-xs text-ink-muted"
          >
            <span class="datum-tick" aria-hidden="true"></span>
            Floor plans · 3D models · from as-built measures
          </figcaption>
        </div>
      </figure>
    </Container>
  </section>

  <!-- ===== Proof band ===== -->
  <ProofStats />

  <!-- ===== Trust bar ===== -->
  <div class="surface-cad border-b border-line">
    <Container class="flex flex-wrap items-center justify-between gap-x-8 gap-y-3 py-5">
      <p class="eyebrow">For architects · contractors · developers · owners</p>
      <p class="font-mono text-xs text-ink-muted">
        {SITE_TAGLINE}
      </p>
    </Container>
  </div>

  <!-- ===== Services grid ===== -->
  <Section surface="paper" labelledby="services-heading">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <SectionHeading
        id="services-heading"
        eyebrow="Services"
        title="Drawings for design, permitting and property."
        intro="As-built documentation, construction drawings, concept design and more - each delivered as clean, usable drawings you can build from."
      />
      <LinkButton href="/services/" variant="outline" size="sm" class="shrink-0">
        All services
      </LinkButton>
    </div>
    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.map((s, i) => (
          <ServiceCard
            index={i}
            href={`/services/${s.id}/`}
            title={s.data.title}
            eyebrow={s.data.eyebrow}
            summary={s.data.summary}
            deliverables={s.data.deliverables.slice(0, 3)}
            optional={s.data.optional}
          />
        ))
      }
    </div>
  </Section>

  <!-- ===== Choose your route ===== -->
  <RouteFinder />

  <!-- ===== Deliverables strip ===== -->
  <Section surface="stone" labelledby="deliverables-heading">
    <SectionHeading
      id="deliverables-heading"
      eyebrow="What you receive"
      title="Clean sheets, at the scale you need."
      intro="Every drawing is issued to a consistent layer structure, with a clear title block, scale bar and north point - so it reads the same on screen, on paper and in CAD."
    />
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      <figure>
        <div class="title-block aspect-[4/3] overflow-hidden">
          <img
            src="/projects/commercial-floorplan.webp"
            alt="As-built floor plan for a commercial building"
            loading="lazy"
            decoding="async"
            class="h-full w-full bg-white object-cover object-top"
          />
        </div>
        <figcaption class="mt-3 font-mono text-xs text-ink-muted">
          As-built floor plan · 1/8" = 1'-0" · DWG + PDF
        </figcaption>
      </figure>
      <figure>
        <div class="title-block aspect-[4/3] overflow-hidden">
          <img
            src="/projects/area-schedule.webp"
            alt="Square-footage schedule across multiple floors"
            loading="lazy"
            decoding="async"
            class="h-full w-full bg-white object-cover object-top"
          />
        </div>
        <figcaption class="mt-3 font-mono text-xs text-ink-muted">
          Area schedule · by suite · PDF + XLSX
        </figcaption>
      </figure>
      <figure>
        <div class="title-block aspect-[4/3] overflow-hidden">
          <img
            src="/projects/suites-plan.webp"
            alt="Lease exhibit showing demised suites and common areas"
            loading="lazy"
            decoding="async"
            class="h-full w-full bg-white object-cover object-top"
          />
        </div>
        <figcaption class="mt-3 font-mono text-xs text-ink-muted">
          Lease exhibit · demised suites · PDF + DWG
        </figcaption>
      </figure>
    </div>
    <p class="mt-6 max-w-2xl text-sm text-ink-muted">
      Recent project work. Client names and property addresses have been removed.
    </p>
  </Section>

  <!-- ===== Process ===== -->
  <Section surface="paper" labelledby="process-heading">
    <SectionHeading
      id="process-heading"
      eyebrow="Process"
      title="A clear route from inquiry to delivery."
      intro="Four steps, every project. You always know what happens next and what you will receive."
    />
    <ProcessStrip steps={process} class="mt-12" />
  </Section>

  <!-- ===== Why MeasuredPlan ===== -->
  <Section surface="cad" labelledby="why-heading">
    <SectionHeading
      id="why-heading"
      eyebrow="Why MeasuredPlan"
      title="Accuracy, documented and easy to use."
      intro="The value is not only in the measurement - it is in drawings that are correct, consistent and ready for the next person to work from."
    />
    <div class="mt-12 grid gap-x-8 gap-y-10 sm:grid-cols-2 lg:grid-cols-4">
      {proof.map((p) => <ProofPoint stat={p.stat} label={p.label} note={p.note} />)}
    </div>
  </Section>

  <!-- ===== Featured projects ===== -->
  <Section surface="paper" labelledby="projects-heading">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <SectionHeading
        id="projects-heading"
        eyebrow="Selected work"
        title="Recent projects."
        intro="A sample of as-built drawings and documentation across the services we offer."
      />
      <LinkButton href="/projects/" variant="outline" size="sm" class="shrink-0">
        View all
      </LinkButton>
    </div>
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {
        projects.map((p) => (
          <a
            href={`/projects/${p.id}/`}
            class="title-block group flex flex-col overflow-hidden transition-[transform,box-shadow,border-color] duration-200 ease-out hover:-translate-y-1 hover:border-line-strong hover:shadow-lg"
          >
            <div class="aspect-[4/3] overflow-hidden border-b border-line">
              {p.data.image ? (
                <img
                  src={p.data.image}
                  alt={`${p.data.title} - ${p.data.buildingType} in ${p.data.location} by MeasuredPlan`}
                  loading="lazy"
                  decoding="async"
                  class="h-full w-full bg-white object-cover object-top transition-transform duration-300 ease-out group-hover:scale-[1.03]"
                />
              ) : (
                <PlanThumb variant={p.data.variant} label={p.data.title} />
              )}
            </div>
            <div class="flex flex-1 flex-col p-6">
              <div class="flex items-center gap-2.5">
                <span class="datum-tick" aria-hidden="true" />
                <span class="eyebrow">{p.data.buildingType}</span>
              </div>
              <h3 class="mt-3 text-lg leading-snug text-ink transition-colors group-hover:text-red-deep">
                {p.data.title}
              </h3>
              <p class="mt-2 text-base leading-relaxed text-ink-muted">
                {p.data.scopeLine}
              </p>
            </div>
          </a>
        ))
      }
    </div>
  </Section>

  <!-- ===== Testimonials ===== -->
  <Section surface="stone" labelledby="testimonials-heading">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <SectionHeading
        id="testimonials-heading"
        eyebrow="Working with us"
        title="What clients say."
        intro="A single accurate base that every consultant on the project can rely on - measured once, drawn properly."
      />
      <LinkButton href="/about/" variant="outline" size="sm" class="shrink-0">
        About the practice
      </LinkButton>
    </div>
    <Testimonials items={testimonials} />
  </Section>

  <!-- ===== FAQ preview ===== -->
  <Section surface="paper" labelledby="faq-heading">
    <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:gap-16">
      <SectionHeading
        id="faq-heading"
        eyebrow="Questions"
        title="What clients ask before starting."
        intro="A few of the most common questions. The full list is on the FAQ page."
      />
      <div>
        <Faq items={homeFaqs} />
        <div class="mt-8">
          <LinkButton href="/faq/" variant="ghost" size="sm">
            All questions →
          </LinkButton>
        </div>
      </div>
    </div>
  </Section>

  <CTASection secondaryLabel="View services" secondaryHref="/services" proof={false} />
</DefaultLayout>

<script>
  // Hero crossfade. Advances only when the tab is visible and motion is
  // allowed; reduced-motion visitors simply keep the first frame. Uses
  // opacity classes already on each <img>, so no-JS shows the first frame too.
  (() => {
    const stack = document.querySelector<HTMLElement>("[data-hero-slides]");
    if (!stack) return;
    const slides = Array.from(
      stack.querySelectorAll<HTMLImageElement>("[data-hero-slide]"),
    );
    if (slides.length < 2) return;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)");
    if (reduce.matches) return;

    let current = 0;
    const HOLD = 5200;
    const show = (next: number) => {
      slides[current].classList.replace("opacity-100", "opacity-0");
      slides[current].setAttribute("aria-hidden", "true");
      slides[next].classList.replace("opacity-0", "opacity-100");
      slides[next].removeAttribute("aria-hidden");
      current = next;
    };

    let timer = 0;
    const tick = () => {
      if (document.visibilityState === "visible") {
        show((current + 1) % slides.length);
      }
      timer = window.setTimeout(tick, HOLD);
    };
    timer = window.setTimeout(tick, HOLD);

    reduce.addEventListener?.("change", (e) => {
      if (e.matches) window.clearTimeout(timer);
    });
  })();
</script>

<style>
  /* Ken Burns drift: a barely-there, cinematic slow zoom on each hero frame so
     the render reads as atmosphere rather than a static image. Scale-only (never
     below 1) so object-cover never reveals an edge; each frame gets its own
     origin + duration so the frames never drift in sync. Compositor-only
     (transform), and fully disabled under reduced motion. */
  @media (prefers-reduced-motion: no-preference) {
    .hero-slide {
      will-change: transform;
      animation: hero-kenburns 22s ease-in-out infinite alternate;
    }
    .hero-slide:nth-of-type(1) {
      transform-origin: 32% 42%;
      animation-duration: 22s;
    }
    .hero-slide:nth-of-type(2) {
      transform-origin: 68% 40%;
      animation-duration: 25s;
    }
    .hero-slide:nth-of-type(3) {
      transform-origin: 46% 66%;
      animation-duration: 19s;
    }
  }
  @keyframes hero-kenburns {
    from {
      transform: scale(1.015);
    }
    to {
      transform: scale(1.075);
    }
  }
</style>

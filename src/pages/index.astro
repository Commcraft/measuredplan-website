    </div>

    <!-- Reassurance + CTA -->
    <div class="title-block mt-10 flex flex-col items-start gap-6 bg-white p-6 sm:flex-row sm:items-center sm:justify-between sm:p-8">
      <p class="max-w-3xl text-base leading-relaxed text-ink">
        Not sure which drawing you need? Tell us the property address, what the
        drawing is for, and your deadline. We'll recommend the correct route -
        floor plan, as-built drawings, square-footage report, lease exhibit, CAD
        redraw or scan-to-CAD - before you commit.
      </p>
      <LinkButton href="/contact/" size="lg" class="shrink-0">
        Tell us about your property
      </LinkButton>
    </div>
  </Section>

  <!-- ===== Deliverables strip ===== -->
  <Section surface="stone" labelledby="deliverables-heading">
    <SectionHeading
      id="deliverables-heading"
      eyebrow="What you receive"
      title="Clean sheets, at the scale you need."

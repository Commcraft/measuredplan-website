---
import { getCollection } from "astro:content";

import Container from "@/components/Container.astro";
import CTASection from "@/components/CTASection.astro";
import Eyebrow from "@/components/Eyebrow.astro";
import Faq from "@/components/Faq.astro";
import HeroField from "@/components/HeroField.astro";
import LinkButton from "@/components/LinkButton.astro";
import PlanThumb from "@/components/PlanThumb.astro";
import ProcessStrip from "@/components/ProcessStrip.astro";
import ProofPoint from "@/components/ProofPoint.astro";
import Section from "@/components/Section.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import ServiceCard from "@/components/ServiceCard.astro";
import Testimonials from "@/components/Testimonials.astro";
import { SITE_TAGLINE, BUSINESS } from "@/consts";
import DefaultLayout from "@/layouts/DefaultLayout.astro";
import { faqPageJsonLd } from "@/lib/seo";

const services = (await getCollection("services"))
  .filter((s) => !s.data.landingOnly)
  .sort((a, b) => a.data.order - b.data.order);
const projects = (await getCollection("projects"))
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const testimonials = (await getCollection("testimonials"))
  .sort((a, b) => a.data.order - b.data.order)
  .map((t) => t.data);

const allFaqs = (await getCollection("faqs")).sort(
  (a, b) => a.data.order - b.data.order,
);
const homeFaqs = allFaqs
  .filter((f) => f.data.services.length === 0)
  .slice(0, 5)
  .map((f) => ({ question: f.data.question, answer: f.data.answer }));

// Line icons for each route (drawn as SVG paths on a technical square tile).
const routeIcons: Record<string, string[]> = {
  house: ["M3 10.5 12 4l9 6.5", "M5 9.5V20h14V9.5"],
  plan: ["M4 4h16v16H4z", "M4 11h9", "M13 4v16"],
  building: [
    "M6 21V4h12v17",
    "M9.5 8h.01",
    "M14.5 8h.01",
    "M9.5 12h.01",
    "M14.5 12h.01",
    "M9.5 16h.01",
    "M14.5 16h.01",
  ],
  doc: ["M8 3h6l4 4v14H8z", "M14 3v5h4"],
  scan: ["M12 3v3M12 18v3M3 12h3M18 12h3", "M12 8.5a3.5 3.5 0 100 7 3.5 3.5 0 000-7z"],
  permit: ["M7 3h8l3 3v15H7z", "M15 3v3h3", "M10 13l2 2 4-4"],
  concept: ["M4 20l2-0.5 11-11-1.5-1.5L4.5 18z", "M14 6l1.5 1.5", "M4 20l0.6-2"],
  hoa: ["M3 11l9-7 9 7", "M6 10v10h12V10", "M9.5 14.5l1.8 1.8 3.2-3.2"],
};

const routes = [
  {
    icon: "house",
    need: "I'm renovating or designing from an existing building.",
    label: "As-built documentation",
    href: "/services/measured-building-surveys/",
  },
  {
    icon: "plan",
    need: "I need square footage or a floor plan for a listing.",
    label: "Floor plan & square-footage report",
    href: "/services/floor-plans-square-footage/",
  },
  {
    icon: "permit",
    need: "I need permit-ready drawings to price and build from.",
    label: "Construction drawings",
    href: "/services/construction-drawings/",
  },
  {
    icon: "concept",
    need: "I'm building new or reworking a layout.",
    label: "Concept design",
    href: "/services/concept-design/",
  },
  {
    icon: "building",
    need: "I need drawings for a lease, suite or commercial space.",
    label: "Lease & BOMA area plans",
    href: "/services/lease-plans/",
  },
  {
    icon: "doc",
    need: "I have an old PDF, sketch or plan that needs to become CAD.",
    label: "CAD redraw / drafting",
    href: "/services/cad-drafting/",
  },
  {
    icon: "hoa",
    need: "I need drawings for HOA architectural approval.",
    label: "HOA design & approval",
    href: "/services/hoa-design-approval/",
  },
  {
    icon: "scan",
    need: "The building is complex and needs detailed capture.",
    label: "3D laser scanning / scan-to-CAD",
    href: "/services/3d-scanning/",
  },
];

const process = [
  {
    title: "Inquiry",
    body: "Send the property details and what the drawings are for. We confirm scope, format and a clear price.",
  },
  {
    title: "Site visit",
    body: "We measure on site, recording the building or site accurately to a stated datum.",
  },
  {
    title: "Drawing",
    body: "We draft in CAD to a consistent layer structure, checked against the recorded measurements.",
  },
  {
    title: "Delivery",
    body: "You receive a clean, scaled set in the agreed formats, with a revision included.",
  },
];

const trust = [
  "On-site measurement",
  "Layered CAD output",
  `${BUSINESS.formats.join(" · ")} delivery`,
  "Starting-price quotes",
];

const proof = [
  {
    stat: "PDF · DWG · IFC",
    label: "Delivered in usable formats",
    note: "Layered AutoCAD DWG and scaled PDF as standard, IFC where a model is needed.",
  },
  {
    stat: "Revisions",
    label: "Built into the process",
    note: "Drawings are checked before issue; corrections against the recorded measurements are included.",
  },
  {
    stat: "Clear pricing",
    label: "Confirmed before we start",
    note: "Starting prices published by service; the final scope and price are confirmed before work begins.",
  },
  {
    stat: "Western NC",
    label: "Based locally",
    note: "On-site work across the region, without the travel markup of an out-of-town firm.",
  },
];
---

<DefaultLayout jsonLd={[faqPageJsonLd(homeFaqs)]}>
  <!-- ===== Hero ===== -->
  <section class="relative overflow-hidden border-b border-line bg-paper">
    <HeroField />
    <Container class="relative z-10 grid gap-12 py-16 lg:grid-cols-[1.05fr_1fr] lg:items-center lg:gap-16 lg:py-24">
      <div>
        <Eyebrow class="mb-6">As-built & design drafting practice</Eyebrow>
        <h1 class="text-[2.3rem] leading-[1.05] sm:text-5xl lg:text-[3.5rem]">
          As-built, construction and concept drawings for Western North
          Carolina<span class="title-dot" aria-hidden="true"></span>
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-muted">
          Drawn to ANSI, NCREC and local permitting standards - for property
          owners, contractors and homebuilders.
        </p>
        <div class="mt-9 flex flex-wrap gap-3">
          <LinkButton href="/contact/" size="lg">Request a quote</LinkButton>
          <LinkButton href="/projects/" variant="outline" size="lg">
            View sample plans
          </LinkButton>
        </div>
        <ul class="mt-10 flex flex-wrap gap-x-6 gap-y-3">
          {
            trust.map((item) => (
              <li class="flex items-center gap-2 font-mono text-xs text-ink-muted">
                <span class="h-1 w-1 bg-line-strong" aria-hidden="true" />
                {item}
              </li>
            ))
          }
        </ul>
      </div>
      <figure class="relative">
        <div class="title-block overflow-hidden shadow-lg">
          <img
            src="/projects/luxury-home-3d.webp"
            alt="A 3D model produced from a MeasuredPlan as-built measure"
            width="1600"
            height="1010"
            fetchpriority="high"
            decoding="async"
            class="block h-auto w-full bg-white"
          />
          <figcaption
            class="flex items-center gap-2.5 border-t border-line bg-white px-4 py-2.5 font-mono text-xs text-ink-muted"
          >
            <span class="datum-tick" aria-hidden="true"></span>
            3D model · from an as-built measure
          </figcaption>
        </div>
      </figure>
    </Container>
  </section>

  <!-- ===== Trust bar ===== -->
  <div class="surface-cad border-b border-line">
    <Container class="flex flex-wrap items-center justify-between gap-x-8 gap-y-3 py-5">
      <p class="eyebrow">For architects · contractors · developers · owners</p>
      <p class="font-mono text-xs text-ink-muted">
        {SITE_TAGLINE}
      </p>
    </Container>
  </div>

  <!-- ===== Services grid ===== -->
  <Section surface="paper" labelledby="services-heading">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <SectionHeading
        id="services-heading"
        eyebrow="Services"
        title="Drawings for design, permitting and property."
        intro="From as-built documentation to construction drawings and concept design, each service is delivered as clean, usable drawings. Not sure which you need? We will tell you."
      />
      <LinkButton href="/services/" variant="outline" size="sm" class="shrink-0">
        All services
      </LinkButton>
    </div>
    <div data-reveal class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.map((s) => (
          <ServiceCard
            href={`/services/${s.id}/`}
            title={s.data.title}
            eyebrow={s.data.eyebrow}
            summary={s.data.summary}
            deliverables={s.data.deliverables.slice(0, 3)}
            optional={s.data.optional}
          />
        ))
      }
    </div>
  </Section>

  <!-- ===== Choose your route ===== -->
  <Section surface="cad" labelledby="route-heading">
    <SectionHeading
      id="route-heading"
      eyebrow="Choose your route"
      title="Which drawing do you actually need?"
      intro="Match what you're trying to do to the right service - or let us point you to it. Each route links straight to the details."
    />
    <div class="mt-10 border-t border-line">
      {
        routes.map((r) => (
          <a
            href={r.href}
            class="group relative flex items-center gap-4 overflow-hidden border-b border-line py-4 pr-3 pl-4 transition-colors hover:bg-white sm:gap-5"
          >
            <span
              class="absolute top-0 left-0 h-full w-[3px] origin-top scale-y-0 bg-red transition-transform duration-200 ease-out group-hover:scale-y-100"
              aria-hidden="true"
            />
            <span class="grid size-11 shrink-0 place-items-center border border-line bg-white text-ink transition-colors duration-150 group-hover:border-ink group-hover:bg-ink group-hover:text-paper">
              <svg
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.4"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                {routeIcons[r.icon].map((d) => (
                  <path d={d} />
                ))}
              </svg>
            </span>
            <span class="min-w-0 flex-1">
              <span class="block text-[1.02rem] leading-snug text-ink">
                <span class="text-line-strong">“</span>
                {r.need}
                <span class="text-line-strong">”</span>
              </span>
              <span class="mt-1 flex items-center gap-1.5 font-mono text-xs text-red-deep sm:hidden">
                {r.label}
                <svg
                  width="13"
                  height="13"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.6"
                  aria-hidden="true"
                >
                  <path
                    d="M5 12h14M13 6l6 6-6 6"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
            </span>
            <span class="hidden shrink-0 items-center gap-2 font-mono text-sm text-ink-muted transition-colors group-hover:text-red-deep sm:flex">
              {r.label}
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                aria-hidden="true"
                class="shrink-0 transition-transform duration-150 group-hover:translate-x-1"
              >
                <path
                  d="M5 12h14M13 6l6 6-6 6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </span>
          </a>
        ))
      }
    </div>

    <!-- Reassurance + CTA -->
    <div class="title-block mt-10 flex flex-col items-start gap-6 bg-white p-6 sm:flex-row sm:items-center sm:justify-between sm:p-8">
      <p class="max-w-3xl text-[1.05rem] leading-relaxed text-ink">
        Not sure which drawing you need? Tell us the property address, what the
        drawing is for, and your deadline. We'll recommend the correct route -
        floor plan, as-built drawings, square-footage report, lease exhibit, CAD
        redraw or scan-to-CAD - before you commit.
      </p>
      <LinkButton href="/contact/" size="lg" class="shrink-0">
        Tell us about your property
      </LinkButton>
    </div>
  </Section>

  <!-- ===== Deliverables strip ===== -->
  <Section surface="stone" labelledby="deliverables-heading">
    <SectionHeading
      id="deliverables-heading"
      eyebrow="What you receive"
      title="Clean sheets, at the scale you need."
      intro="Every drawing is issued to a consistent layer structure, with a clear title block, scale bar and north point - so it reads the same on screen, on paper and in CAD."
    />
    <div data-reveal class="mt-12 grid gap-6 md:grid-cols-3">
      <figure>
        <div class="title-block aspect-[4/3] overflow-hidden">
          <img
            src="/projects/commercial-floorplan.webp"
            alt="As-built floor plan for a commercial building"
            loading="lazy"
            decoding="async"
            class="h-full w-full bg-white object-cover object-top"
          />
        </div>
        <figcaption class="mt-3 font-mono text-xs text-ink-muted">
          As-built floor plan · 1/8" = 1'-0" · DWG + PDF
        </figcaption>
      </figure>
      <figure>
        <div class="title-block aspect-[4/3] overflow-hidden">
          <img
            src="/projects/area-schedule.webp"
            alt="Square-footage schedule across multiple floors"
            loading="lazy"
            decoding="async"
            class="h-full w-full bg-white object-cover object-top"
          />
        </div>
        <figcaption class="mt-3 font-mono text-xs text-ink-muted">
          Area schedule · by suite · PDF + XLSX
        </figcaption>
      </figure>
      <figure>
        <div class="title-block aspect-[4/3] overflow-hidden">
          <img
            src="/projects/suites-plan.webp"
            alt="Lease exhibit showing demised suites and common areas"
            loading="lazy"
            decoding="async"
            class="h-full w-full bg-white object-cover object-top"
          />
        </div>
        <figcaption class="mt-3 font-mono text-xs text-ink-muted">
          Lease exhibit · demised suites · PDF + DWG
        </figcaption>
      </figure>
    </div>
    <p class="mt-6 max-w-2xl text-sm text-ink-muted">
      Recent project work. Client names and property addresses have been removed.
    </p>
  </Section>

  <!-- ===== Process ===== -->
  <Section surface="paper" labelledby="process-heading">
    <SectionHeading
      id="process-heading"
      eyebrow="Process"
      title="A clear route from inquiry to delivery."
      intro="Four steps, every project. You always know what happens next and what you will receive."
    />
    <ProcessStrip steps={process} class="mt-12" />
  </Section>

  <!-- ===== Why MeasuredPlan ===== -->
  <Section surface="cad" labelledby="why-heading">
    <SectionHeading
      id="why-heading"
      eyebrow="Why MeasuredPlan"
      title="Accuracy, documented and easy to use."
      intro="The value is not only in the measurement - it is in drawings that are correct, consistent and ready for the next person to work from."
    />
    <div data-reveal class="mt-12 grid gap-x-8 gap-y-10 sm:grid-cols-2 lg:grid-cols-4">
      {proof.map((p) => <ProofPoint stat={p.stat} label={p.label} note={p.note} />)}
    </div>
  </Section>

  <!-- ===== Featured projects ===== -->
  <Section surface="paper" labelledby="projects-heading">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <SectionHeading
        id="projects-heading"
        eyebrow="Selected work"
        title="Recent projects."
        intro="A sample of as-built drawings and documentation across the services we offer."
      />
      <LinkButton href="/projects/" variant="outline" size="sm" class="shrink-0">
        View all
      </LinkButton>
    </div>
    <div data-reveal class="mt-12 grid gap-6 md:grid-cols-3">
      {
        projects.map((p) => (
          <article class="flex flex-col">
            {p.data.image ? (
              <div class="title-block aspect-[4/3] overflow-hidden">
                <img
                  src={p.data.image}
                  alt={`${p.data.title} - measured drawing`}
                  loading="lazy"
            decoding="async"
                  class="h-full w-full bg-white object-cover object-top"
                />
              </div>
            ) : (
              <PlanThumb variant={p.data.variant} label={p.data.title} />
            )}
            <div class="mt-4">
              <span class="eyebrow">{p.data.buildingType}</span>
              <h3 class="mt-2 text-lg leading-snug">{p.data.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-muted">
                {p.data.scopeLine}
              </p>
            </div>
          </article>
        ))
      }
    </div>
  </Section>

  <!-- ===== Testimonials ===== -->
  <Section surface="stone" labelledby="testimonials-heading">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <SectionHeading
        id="testimonials-heading"
        eyebrow="Working with us"
        title="What clients say."
        intro="A single accurate base that every consultant on the project can rely on - measured once, drawn properly."
      />
      <LinkButton href="/about/" variant="outline" size="sm" class="shrink-0">
        About the practice
      </LinkButton>
    </div>
    <Testimonials items={testimonials} />
  </Section>

  <!-- ===== FAQ preview ===== -->
  <Section surface="paper" labelledby="faq-heading">
    <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:gap-16">
      <SectionHeading
        id="faq-heading"
        eyebrow="Questions"
        title="What clients ask before starting."
        intro="A few of the most common questions. The full list is on the FAQ page."
      />
      <div>
        <Faq items={homeFaqs} />
        <div class="mt-8">
          <LinkButton href="/faq/" variant="ghost" size="sm">
            All questions →
          </LinkButton>
        </div>
      </div>
    </div>
  </Section>

  <CTASection secondaryLabel="View services" secondaryHref="/services" />
</DefaultLayout>

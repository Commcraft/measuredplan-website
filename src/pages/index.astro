  <!-- ===== FAQ preview ===== -->
  <Section surface="paper" labelledby="faq-heading">
    <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:gap-16">
      <SectionHeading
        id="faq-heading"
        eyebrow="Questions"
        title="What clients ask before starting."
        intro="A few of the most common questions. The full list is on the FAQ page."
      />
      <div>
        <Faq items={homeFaqs} />
        <div class="mt-8">
          <LinkButton href="/faq/" variant="ghost" size="sm">
            All questions →
          </LinkButton>
        </div>
      </div>
    </div>
  </Section>

  <CTASection secondaryLabel="View services" secondaryHref="/services" proof={false} />
</DefaultLayout>

<script>
  // Hero crossfade. Advances only when the tab is visible and motion is
  // allowed; reduced-motion visitors simply keep the first frame. Uses
  // opacity classes already on each <img>, so no-JS shows the first frame too.
  (() => {
    const stack = document.querySelector<HTMLElement>("[data-hero-slides]");
    if (!stack) return;
    const slides = Array.from(
      stack.querySelectorAll<HTMLImageElement>("[data-hero-slide]"),
    );
    if (slides.length < 2) return;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)");
    if (reduce.matches) return;

    let current = 0;
    const HOLD = 5200;
    const show = (next: number) => {
      slides[current].classList.replace("opacity-100", "opacity-0");
      slides[current].setAttribute("aria-hidden", "true");
      slides[next].classList.replace("opacity-0", "opacity-100");
      slides[next].removeAttribute("aria-hidden");
      current = next;
    };

    let timer = 0;
    const tick = () => {
      if (document.visibilityState === "visible") {
        show((current + 1) % slides.length);
      }
      timer = window.setTimeout(tick, HOLD);
    };
    timer = window.setTimeout(tick, HOLD);

    reduce.addEventListener?.("change", (e) => {
      if (e.matches) window.clearTimeout(timer);
    });
  })();
</script>

<style>
  /* Hero registration marks: draw in once on load (CSS-only, no JS needed).
     Reduced motion -> shown statically. */
  .hero-anno path {
    stroke: rgba(11, 23, 38, 0.4);
    stroke-width: 1.5;
    vector-effect: non-scaling-stroke;
    stroke-linecap: square;
  }
  .hero-datum {
    fill: #c21f3a;
    opacity: 1;
  }
  @media (prefers-reduced-motion: no-preference) {
    .hero-anno path {
      stroke-dasharray: 64;
      stroke-dashoffset: 64;
      animation: hero-draw 0.7s ease-out forwards;
    }
    .hero-anno path:nth-of-type(1) {
      animation-delay: 0.35s;
    }
    .hero-anno path:nth-of-type(2) {
      animation-delay: 0.47s;
    }
    .hero-anno path:nth-of-type(3) {
      animation-delay: 0.59s;
    }
    .hero-anno path:nth-of-type(4) {
      animation-delay: 0.71s;
    }
    .hero-datum {
      animation: hero-fade 0.5s ease-out 0.95s both;
    }
  }
  @keyframes hero-draw {
    to {
      stroke-dashoffset: 0;
    }
  }
  @keyframes hero-fade {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  /* Ken Burns drift: a barely-there, cinematic slow zoom on each hero frame so
     the render reads as atmosphere rather than a static image. Scale-only (never
     below 1) so object-cover never reveals an edge; each frame gets its own
     origin + duration so the three never drift in sync. Compositor-only
     (transform), and fully disabled under reduced motion. The registration-mark
     overlay is a sibling, so it stays pinned to the frame while the image moves. */
  @media (prefers-reduced-motion: no-preference) {
    .hero-slide {

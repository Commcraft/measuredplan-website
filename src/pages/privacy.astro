---
import PageIntro from "@/components/PageIntro.astro";
import Section from "@/components/Section.astro";
import { BUSINESS } from "@/consts";
import DefaultLayout from "@/layouts/DefaultLayout.astro";
import { breadcrumbJsonLd } from "@/lib/seo";

const crumbs = [
  { label: "Home", href: "/" },
  { label: "Privacy", href: "/privacy/" },
];
---

<DefaultLayout
  title="Privacy policy"
  description="How MeasuredPlan collects, uses and protects the personal information you share when requesting a quote or as-built drawings."
  noindex={true}
  jsonLd={[breadcrumbJsonLd(crumbs)]}
>
  <PageIntro
    eyebrow="Legal"
    title="Privacy policy"
    intro="How we handle the information you share when you inquire about, or commission, as-built drawings."
    crumbs={crumbs}
  />

  <Section surface="paper">
    <div
      class="prose prose-sm max-w-2xl prose-headings:font-display prose-headings:tracking-tight prose-headings:text-ink prose-p:text-ink-muted prose-li:text-ink-muted prose-a:text-ink"
    >
      <p class="font-mono text-xs text-ink-muted">Last updated: July 2026</p>

      <h2>Who we are</h2>
      <p>
        {BUSINESS.name} provides measured building drawing services in Asheville
        and Western North Carolina. This policy explains what personal
        information we collect and how we use it.
      </p>

      <h2>Information we collect</h2>
      <ul>
        <li>Contact details you provide - name, email, phone.</li>
        <li>Property details relevant to an as-built project or quote.</li>
        <li>Correspondence and project information you share with us.</li>
      </ul>

      <h2>How we use it</h2>
      <ul>
        <li>To respond to inquiries and prepare quotes.</li>
        <li>To carry out and deliver commissioned work.</li>
        <li>To keep records of projects and correspondence.</li>
      </ul>

      <h2>Sharing and retention</h2>
      <p>
        We do not sell your information. We share it only with the service
        providers we rely on to run the business - such as email, website
        hosting and file delivery - and only as far as needed to respond to you
        and deliver your project. We keep project records for as long as we need
        them to provide our services and to meet legal and accounting
        obligations.
      </p>

      <h2>Your rights</h2>
      <p>
        You can ask us to access, correct or delete the personal information we
        hold about you. To make a request, email us at the address below and we
        will respond within a reasonable time.
      </p>

      <h2>Contact</h2>
      <p>
        For any privacy question, email
        <a href={`mailto:${BUSINESS.email}`}>{BUSINESS.email}</a>.
      </p>
    </div>
  </Section>
</DefaultLayout>

---
import CTASection from "@/components/CTASection.astro";
import Eyebrow from "@/components/Eyebrow.astro";
import PageIntro from "@/components/PageIntro.astro";
import ProofStats from "@/components/ProofStats.astro";
import Section from "@/components/Section.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import ServiceArea from "@/components/ServiceArea.astro";
import SpecTable from "@/components/SpecTable.astro";
import DefaultLayout from "@/layouts/DefaultLayout.astro";
import { breadcrumbJsonLd } from "@/lib/seo";
import alfredasPhoto from "@/assets/team/alfredas-zalys.webp";
import benasPhoto from "@/assets/team/benas-rimsa.webp";
import elenaPhoto from "@/assets/team/elena-survilaite.webp";

const standards = [
  {
    title: "Accuracy first",
    body: "Every drawing starts from on-site measurement, not an assumption. If it is on the plan, it was measured.",
  },
  {
    title: "Clean, consistent layers",
    body: "CAD files follow a consistent layer structure, so the next person can work with them straight away.",
  },
  {
    title: "Readable output",
    body: "Clear title blocks, scale bars and north points. Drawings that read the same on screen, on paper and in CAD.",
  },
  {
    title: "A defined revision process",
    body: "Drawings are checked before issue and revisions are tracked with a reference, so everyone knows which version is current.",
  },
  {
    title: "Sensible file structure",
    body: "Files are named and organized predictably, so you can find and reuse them long after delivery.",
  },
  {
    title: "Practical communication",
    body: "Plain, specific answers about scope, timing and cost - before, during and after the work.",
  },
];

const methodRows = [
  {
    label: "Measurement",
    value: "Laser distance meters and a 3D laser scanner as required",
  },
  {
    label: "Scanning",
    value: "Terrestrial laser scanning for complex and detailed buildings",
  },
  { label: "Drafting", value: "AutoCAD, layered to a consistent standard" },
  {
    label: "Area standards",
    value: "BOMA for commercial, ANSI Z765 for residential",
  },
  {
    label: "Delivery",
    value: "Layered DWG, PDF, IFC and point cloud",
  },
];

const team = [
  {
    name: "Alfredas Zalys",
    role: "CEO",
    photo: alfredasPhoto,
    bio: "Alfredas leads MeasuredPlan with more than 20 years of experience in property measurement and measured building documentation. His work is focused on accuracy, consistency and dependable delivery - ensuring every project is handled with the level of care required for planning, design, leasing and property decision-making.",
  },
  {
    name: "Benas Rimsa",
    role: "COO",
    photo: benasPhoto,
    bio: "Benas brings over 15 years of financial and operational management experience to MeasuredPlan. As COO, he oversees the commercial and operational side of the business, helping ensure clients receive a clear, reliable service with transparent communication, efficient processes and strong value from first inquiry to final delivery.",
  },
  {
    name: "Elena Survilaite",
    role: "CMO",
    photo: elenaPhoto,
    bio: "Elena brings more than 20 years of international marketing experience across Europe, the United States and the Middle East. As CMO, she leads MeasuredPlan's brand, marketing and partnerships - shaping how the practice presents its work and building the relationships that connect it with architects, developers and property owners.",
  },
];

// Leadership section is currently hidden (set true to show it again).
const SHOW_LEADERSHIP = false;

const crumbs = [
  { label: "Home", href: "/" },
  { label: "About", href: "/about/" },
];
---

<DefaultLayout
  title="About MeasuredPlan · Western North Carolina"
  description="MeasuredPlan is an as-built documentation and design drafting practice in Western North Carolina - floor plans, construction drawings, concept design and lease plans, drawn accurately and clearly."
  jsonLd={[breadcrumbJsonLd(crumbs)]}
>
  <PageIntro
    eyebrow="The practice"
    title="A drafting and design documentation practice built on accuracy."
    intro="MeasuredPlan produces precise as-built drawings and design documentation for the people who rely on them - architects, contractors, developers, homebuilders and property owners. The work is deliberately unshowy: measure carefully, draw clearly, deliver something genuinely usable."
    crumbs={crumbs}
  />

  <ProofStats />

  <!-- Story + visual -->
  <Section surface="paper">
    <div class="grid gap-12 lg:grid-cols-[1.2fr_1fr] lg:items-center lg:gap-16">
      <div class="space-y-5 text-base leading-relaxed text-ink-muted">
        <p>
          Good drawings are quiet infrastructure. When a floor plan is accurate,
          a lease exhibit is clear and an as-built reflects the building as it
          really is, the projects built on them run more smoothly - fewer
          surprises, fewer revisions, less wasted cost.
        </p>
        <p>
          That is the whole intent of the practice: to be the dependable
          starting point. We measure what is actually there, draft it to a
          consistent standard, and hand over files that the next person can
          pick up and use without having to check our work.
        </p>
        <p>
          <span class="text-ink">Local and independent.</span> MeasuredPlan is
          an independent as-built documentation practice working across Western
          North Carolina, based in Asheville.
        </p>
      </div>
      <figure>
        <div class="title-block overflow-hidden">
          <img
            src="/projects/commercial-floorplan.webp"
            alt="As-built floor plan from a recent project"
            width="1200"
            height="1156"
            loading="lazy"
            decoding="async"
            class="block h-auto w-full bg-white"
          />
        </div>
        <figcaption class="mt-3 font-mono text-xs text-ink-muted">
          As-built floor plan · recent project
        </figcaption>
      </figure>
    </div>
  </Section>

  <!-- Leadership (hidden - toggle SHOW_LEADERSHIP to restore) -->
  {
    SHOW_LEADERSHIP && (
  <Section surface="cad">
    <SectionHeading
      eyebrow="Leadership"
      title="The people behind the practice."
      intro="MeasuredPlan's leadership covers the technical, commercial and brand sides of every project."
    />
    <div
      data-reveal
      class="mx-auto mt-12 grid max-w-4xl gap-6 sm:grid-cols-2 lg:grid-cols-3"
    >
      {
        team.map((person) => (
          <div class="title-block flex flex-col bg-white p-5 sm:p-6">
            <div class="flex items-center gap-4 sm:gap-5">
              <img
                src={person.photo.src}
                alt={`${person.name}, ${person.role} of MeasuredPlan`}
                width={person.photo.width}
                height={person.photo.height}
                loading="lazy"
                decoding="async"
                class="h-20 w-20 shrink-0 bg-white object-cover sm:h-32 sm:w-32 lg:h-36 lg:w-36"
              />
              <div class="min-w-0">
                <h3 class="text-lg leading-snug text-ink">{person.name}</h3>
                <p class="eyebrow mt-1">{person.role}</p>
              </div>
            </div>
            <p class="mt-4 text-base leading-relaxed text-ink-muted">
              {person.bio}
            </p>
          </div>
        ))
      }
    </div>
  </Section>
    )
  }

  <!-- Standards -->
  <Section surface="stone">
    <SectionHeading
      eyebrow="Our standard"
      title="What “premium” actually means here."
      intro="Not gloss - discipline. These are the concrete standards behind every drawing we issue."
    />
    <div class="mt-12 grid gap-x-12 gap-y-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        standards.map((s, i) => (
          <div class="flex gap-4 border-t border-line pt-5">
            <span class="mt-0.5 font-mono text-sm text-ink-muted">
              {String(i + 1).padStart(2, "0")}
            </span>
            <div>
              <h3 class="text-lg leading-snug">{s.title}</h3>
              <p class="mt-2 text-base leading-relaxed text-ink-muted">{s.body}</p>
            </div>
          </div>
        ))
      }
    </div>
  </Section>

  <!-- Method + equipment -->
  <Section surface="paper">
    <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:gap-16">
      <SectionHeading
        eyebrow="Equipment & method"
        title="How we measure and draft."
      />
      <SpecTable rows={methodRows} />
    </div>
  </Section>

  <!-- Service area -->
  <Section surface="stone" id="service-area" class="scroll-mt-24">
    <SectionHeading
      eyebrow="Service area"
      title="Our core and extended service area."
      intro="MeasuredPlan is based in Asheville and works across Western North Carolina - close-in projects at standard scheduling, and wider coverage with travel folded into the fixed quote."
    />
    <div class="mt-12">
      <ServiceArea />
    </div>
  </Section>

  <!-- Scope & coverage -->
  <Section surface="cad">
    <div class="title-block p-8 sm:p-10">
      <Eyebrow class="mb-5">Scope & coverage</Eyebrow>
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        <div>
          <h3 class="text-base font-medium text-ink">What we do</h3>
          <p class="mt-2 text-sm text-ink-muted">
            As-built and existing-conditions drawings, construction drawings,
            concept design, CAD drafting, lease exhibits, 3D laser scanning and
            HOA design & approval.
          </p>
        </div>
        <div>
          <h3 class="text-base font-medium text-ink">What we don't</h3>
          <p class="mt-2 text-sm text-ink-muted">
            We do not perform licensed land or boundary surveys. Where one is
            needed we can refer a licensed North Carolina surveyor.
          </p>
        </div>
        <div>
          <h3 class="text-base font-medium text-ink">Coverage</h3>
          <p class="mt-2 text-sm text-ink-muted">
            Based in Asheville and working across Western North Carolina.
          </p>
        </div>
      </div>
    </div>
  </Section>

  <CTASection />
</DefaultLayout>

---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";

import CTASection from "@/components/CTASection.astro";
import LinkButton from "@/components/LinkButton.astro";
import PageIntro from "@/components/PageIntro.astro";
import Section from "@/components/Section.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import DefaultLayout from "@/layouts/DefaultLayout.astro";
import { breadcrumbJsonLd } from "@/lib/seo";
import { SITE_URL } from "@/consts";

export const getStaticPaths = (async () => {
  const projects = await getCollection("projects");
  const services = await getCollection("services");
  return projects.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, services },
  }));
}) satisfies GetStaticPaths;

const { entry, services } = Astro.props;
const d = entry.data;
const serviceName = (slug: string) =>
  services.find((s) => s.id === slug)?.data.title ?? slug;

const related = (await getCollection("projects"))
  .filter(
    (p) => p.id !== entry.id && p.data.service.some((s) => d.service.includes(s)),
  )
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const crumbs = [
  { label: "Home", href: "/" },
  { label: "Projects", href: "/projects/" },
  { label: d.title, href: `/projects/${entry.id}/` },
];

const specs = [
  { label: "Building type", value: d.buildingType },
  { label: "Location", value: d.location },
  { label: "Year", value: d.date },
  { label: "Formats", value: d.deliverables.join(" · ") },
];

// CreativeWork structured data for search + AI answer engines.
const projectJsonLd = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: d.title,
  headline: d.title,
  about: d.buildingType,
  locationCreated: { "@type": "Place", name: d.location },
  dateCreated: d.date,
  image: `${SITE_URL}${d.image}`,
  description: d.scopeLine,
  creator: { "@id": `${SITE_URL}/#business` },
  keywords: d.service.map(serviceName).join(", "),
  url: `${SITE_URL}/projects/${entry.id}/`,
};
---

<DefaultLayout
  title={`${d.title} · ${d.location}`}
  description={`${d.scopeLine} A ${d.buildingType.toLowerCase()} project in ${d.location} by MeasuredPlan, Western North Carolina.`}
  image={d.image}
  jsonLd={[breadcrumbJsonLd(crumbs), projectJsonLd]}
>
  <PageIntro
    eyebrow={d.buildingType}
    title={d.title}
    intro={d.scopeLine}
    crumbs={crumbs}
  />

  <Section surface="paper">
    <div class="grid gap-10 lg:grid-cols-[1.5fr_1fr] lg:gap-16">
      <figure>
        {
          d.image && (
            <div class="title-block overflow-hidden">
              <img
                src={d.image}
                alt={`${d.title} - ${d.buildingType} in ${d.location} by MeasuredPlan`}
                decoding="async"
                class="block h-auto w-full bg-white"
              />
            </div>
          )
        }
        <figcaption class="mt-3 font-mono text-xs text-ink-muted">
          {d.buildingType} · {d.location} · {d.date} · client name and address
          removed
        </figcaption>
      </figure>

      <aside class="lg:sticky lg:top-28 lg:h-fit">
        <dl class="divide-y divide-line border-y border-line">
          {
            specs.map((s) => (
              <div class="flex items-baseline justify-between gap-6 py-3.5">
                <dt class="font-mono text-xs uppercase tracking-wide text-ink-muted">
                  {s.label}
                </dt>
                <dd class="text-right text-[0.95rem] text-ink">{s.value}</dd>
              </div>
            ))
          }
        </dl>

        <p class="eyebrow mt-8 mb-3">Services used</p>
        <ul class="flex flex-wrap gap-2">
          {
            d.service.map((s) => (
              <li>
                <a
                  href={`/services/${s}/`}
                  class="inline-block border border-line px-3 py-1.5 font-mono text-xs text-ink-muted transition-colors hover:border-ink hover:text-ink"
                >
                  {serviceName(s)}
                </a>
              </li>
            ))
          }
        </ul>

        <div class="mt-8">
          <LinkButton href="/contact/" size="md">Request a similar quote</LinkButton>
        </div>
      </aside>
    </div>
  </Section>

  {
    related.length > 0 && (
      <Section surface="stone">
        <SectionHeading eyebrow="More work" title="Related projects." />
        <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {related.map((p) => (
            <a href={`/projects/${p.id}/`} class="group flex flex-col">
              {p.data.image && (
                <div class="title-block aspect-[4/3] overflow-hidden transition-colors group-hover:border-line-strong">
                  <img
                    src={p.data.image}
                    alt={`${p.data.title} - ${p.data.buildingType} in ${p.data.location}`}
                    loading="lazy"
                    decoding="async"
                    class="h-full w-full bg-white object-cover object-top transition-transform duration-300 group-hover:scale-[1.03]"
                  />
                </div>
              )}
              <div class="mt-4">
                <span class="eyebrow">{p.data.buildingType}</span>
                <h3 class="mt-2 text-lg leading-snug transition-colors group-hover:text-red-deep">
                  {p.data.title}
                </h3>
                <p class="mt-1 font-mono text-xs text-ink-muted">
                  {p.data.location}
                </p>
              </div>
            </a>
          ))}
        </div>
      </Section>
    )
  }

  <CTASection />
</DefaultLayout>

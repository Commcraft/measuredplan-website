---
import Container from "./Container.astro";
import LinkButton from "./LinkButton.astro";
import Logo from "./Logo.astro";
import WhatsAppLink from "./WhatsAppLink.astro";
import { NAV_LINKS, PRIMARY_CTA, BUSINESS } from "../consts";

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path === href || path.startsWith(href + "/");
---

<header
  class="sticky top-0 z-50 border-b border-line bg-paper/90 backdrop-blur-sm transition-transform duration-300 will-change-transform"
  data-site-header
>
  <Container>
    <div class="flex h-16 items-center justify-between gap-4 sm:h-[4.5rem]">
      <Logo />

      <nav aria-label="Primary" class="hidden lg:block">
        <ul class="flex items-center gap-8">
          {
            NAV_LINKS.map((link) => (
              <li>
                <a
                  href={link.href}
                  aria-current={isActive(link.href) ? "page" : undefined}
                  class:list={[
                    "relative flex items-center gap-2 py-2 text-sm font-medium transition-colors",
                    isActive(link.href)
                      ? "text-ink"
                      : "text-ink-muted hover:text-ink",
                  ]}
                >
                  {isActive(link.href) && (
                    <span class="datum-tick" aria-hidden="true" />
                  )}
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="hidden items-center gap-3 lg:flex">
        <WhatsAppLink variant="icon" />
        <LinkButton href={PRIMARY_CTA.href} size="sm">{PRIMARY_CTA.label}</LinkButton>
      </div>

      <div class="flex items-center gap-1.5 lg:hidden">
        <WhatsAppLink variant="icon" />
        <button
          type="button"
          class="grid size-10 place-items-center border border-line text-ink"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-nav"
          data-menu-toggle
        >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          aria-hidden="true"
          data-icon-open
        >
          <path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round"></path>
        </svg>
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          aria-hidden="true"
          class="hidden"
          data-icon-close
        >
          <path d="M6 6l12 12M18 6L6 18" stroke-linecap="round"></path>
        </svg>
        </button>
      </div>
    </div>
  </Container>

  <!-- Mobile navigation -->
  <div
    id="mobile-nav"
    class="hidden border-t border-line bg-paper lg:hidden"
    data-mobile-nav
    inert
    aria-hidden="true"
  >
    <Container>
      <nav aria-label="Mobile" class="py-4">
        <ul class="flex flex-col divide-y divide-line">
          {
            NAV_LINKS.map((link) => (
              <li>
                <a
                  href={link.href}
                  aria-current={isActive(link.href) ? "page" : undefined}
                  class:list={[
                    "flex items-center gap-2.5 py-3.5 text-base font-medium",
                    isActive(link.href) ? "text-ink" : "text-ink-muted",
                  ]}
                >
                  {isActive(link.href) && (
                    <span class="datum-tick" aria-hidden="true" />
                  )}
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
        <div class="space-y-3 pt-5">
          <LinkButton href={PRIMARY_CTA.href} size="lg" class="w-full">
            {PRIMARY_CTA.label}
          </LinkButton>
          <a
            href={`tel:${BUSINESS.phoneHref}`}
            data-umami-event="Call Click"
            class="flex w-full items-center justify-center gap-2 border border-ink/70 py-3 text-sm font-medium text-ink transition-colors hover:bg-ink hover:text-paper"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"
              ></path>
            </svg>
            Call {BUSINESS.phone}
          </a>
        </div>
      </nav>
    </Container>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
  const panel = document.querySelector<HTMLElement>("[data-mobile-nav]");
  const iconOpen = document.querySelector<SVGElement>("[data-icon-open]");
  const iconClose = document.querySelector<SVGElement>("[data-icon-close]");

  function setOpen(open: boolean) {
    if (!toggle || !panel || !iconOpen || !iconClose) return;
    panel.classList.toggle("hidden", !open);
    if (open) {
      panel.removeAttribute("inert");
      panel.removeAttribute("aria-hidden");
    } else {
      panel.setAttribute("inert", "");
      panel.setAttribute("aria-hidden", "true");
    }
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    iconOpen.classList.toggle("hidden", open);
    iconClose.classList.toggle("hidden", !open);
  }

  toggle?.addEventListener("click", () => {
    const open = toggle.getAttribute("aria-expanded") === "true";
    setOpen(!open);
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") setOpen(false);
  });

  // Close after navigating (view transitions / anchor clicks)
  panel?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => setOpen(false)),
  );

  // Smart sticky header: hide on scroll down, reveal on scroll up - reclaims
  // vertical space on long pages. Always shown near the top and while the menu
  // is open; a small threshold avoids flicker on tiny scrolls.
  const header = document.querySelector<HTMLElement>("[data-site-header]");
  if (header) {
    let lastY = window.scrollY;
    let ticking = false;
    const THRESHOLD = 8;
    function update() {
      ticking = false;
      const y = window.scrollY;
      const menuOpen = toggle?.getAttribute("aria-expanded") === "true";
      // Desktop (>= lg) has no sticky bottom CTA bar, so the header stays
      // persistently visible - nav and the quote CTA are always in reach. On
      // mobile the header hides on scroll-down (the sticky bottom bar keeps the
      // CTA available), the current best-practice hybrid for long pages.
      if (window.innerWidth >= 1024 || menuOpen || y < 80) {
        header!.style.transform = "";
        lastY = y;
        return;
      }
      if (y > lastY + THRESHOLD) {
        header!.style.transform = "translateY(-100%)"; // scrolling down
        lastY = y;
      } else if (y < lastY - THRESHOLD) {
        header!.style.transform = ""; // scrolling up
        lastY = y;
      }
    }
    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(update);
        }
      },
      { passive: true },
    );
  }
</script>

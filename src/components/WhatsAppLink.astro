---
// WhatsApp click-to-chat link. One glyph + href, three presentations:
//  - "solid"  : ink button with a red glyph and label (contact page, mobile menu)
//  - "icon"   : compact square icon button (desktop header)
//  - "footer" : inline text link with a small glyph (footer, on the dark band)
import { WHATSAPP } from "../consts";

interface Props {
  variant?: "solid" | "icon" | "footer";
  class?: string;
}
const { variant = "solid", class: className = "" } = Astro.props;

const WA_PATH =
  "M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.885-9.885 9.885M20.52 3.449C18.24 1.245 15.24 0 12.045 0 5.463 0 .103 5.36.1 11.945c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662a11.9 11.9 0 005.71 1.456h.005c6.582 0 11.945-5.36 11.948-11.945a11.9 11.9 0 00-3.48-8.4";

// Official WhatsApp green, for instant recognition.
const WA_GREEN = "#25D366";

const base = "group inline-flex items-center transition-all duration-150 ease-out";
const variants = {
  solid:
    "gap-2.5 border border-ink bg-ink py-2.5 pr-5 pl-3.5 text-sm font-medium text-paper hover:-translate-y-0.5 hover:shadow-md",
  // Bare icon, no box - just the mark.
  icon: "-m-1.5 justify-center p-1.5 hover:scale-110",
  footer: "gap-2 text-[0.95rem] text-ink-muted-inverse hover:text-paper",
};

const iconClass =
  variant === "solid"
    ? "shrink-0 transition-transform duration-150 group-hover:scale-110"
    : "shrink-0";
const iconSize = variant === "footer" ? 16 : variant === "icon" ? 24 : 19;
---

<a
  href={WHATSAPP.href}
  target="_blank"
  rel="noopener"
  aria-label="Message MeasuredPlan on WhatsApp"
  data-umami-event="WhatsApp Click"
  class:list={[base, variants[variant], className]}
>
  <svg
    width={iconSize}
    height={iconSize}
    viewBox="0 0 24 24"
    fill={WA_GREEN}
    aria-hidden="true"
    class={iconClass}
  >
    <path d={WA_PATH}></path>
  </svg>
  {variant === "solid" && <span>Message on WhatsApp</span>}
  {variant === "footer" && <span>WhatsApp</span>}
</a>

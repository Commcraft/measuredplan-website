---
// Vertical rhythm wrapper. `surface` sets the section background per the
// color rules: paper (canvas), white (raised), stone (editorial),
// cad (technical), ink (single dark band).
import Container from "./Container.astro";

type Surface = "paper" | "white" | "stone" | "cad" | "ink";
interface Props {
  surface?: Surface;
  id?: string;
  class?: string;
  containerClass?: string;
  bare?: boolean; // skip the inner Container
  labelledby?: string;
  reveal?: boolean; // subtle fade-up on scroll (site-wide default)
}

const {
  surface = "paper",
  id,
  class: className = "",
  containerClass = "",
  bare = false,
  labelledby,
  reveal = true,
} = Astro.props;

const surfaces: Record<Surface, string> = {
  paper: "bg-paper",
  white: "bg-white",
  stone: "surface-stone",
  cad: "surface-cad",
  ink: "band-ink",
};
---

<section
  id={id}
  aria-labelledby={labelledby}
  class:list={[
    surfaces[surface],
    "section-cv py-14 sm:py-18 lg:py-24",
    className,
  ]}
>
  {
    bare ? (
      reveal ? (
        <div data-reveal>
          <slot />
        </div>
      ) : (
        <slot />
      )
    ) : (
      <Container class={containerClass}>
        {reveal ? (
          <div data-reveal>
            <slot />
          </div>
        ) : (
          <slot />
        )}
      </Container>
    )
  }
</section>

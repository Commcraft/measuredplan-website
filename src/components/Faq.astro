---
// Accessible FAQ list using native <details> (no JS, keyboard-friendly).
interface Item {
  question: string;
  answer: string;
}
interface Props {
  items: Item[];
  class?: string;
}
const { items, class: className = "" } = Astro.props;
---

<div class:list={["divide-y divide-line border-y border-line", className]}>
  {
    items.map((item) => (
      <details class="group">
        <summary class="flex cursor-pointer list-none items-start justify-between gap-6 py-5 text-left [&::-webkit-details-marker]:hidden">
          <span class="text-base font-medium text-ink sm:text-lg">
            {item.question}
          </span>
          <span
            class="mt-1 grid size-6 shrink-0 place-items-center border border-line text-ink transition-transform duration-150 group-open:rotate-45"
            aria-hidden="true"
          >
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path
                d="M6 1v10M1 6h10"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
              />
            </svg>
          </span>
        </summary>
        <p class="max-w-2xl pb-6 text-[0.95rem] leading-relaxed text-ink-muted">
          {item.answer}
        </p>
      </details>
    ))
  }
</div>

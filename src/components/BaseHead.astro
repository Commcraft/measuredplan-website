---
// Global <head>. Imported once via DefaultLayout so global.css loads everywhere.
import "../styles/global.css";
import { SITE_METADATA, ORGANIZATION_JSONLD } from "../consts";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  /** Extra JSON-LD objects for this page (Service, FAQPage, BreadcrumbList). */
  jsonLd?: Record<string, unknown>[];
  noindex?: boolean;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image, jsonLd = [], noindex = false } = Astro.props;
const finalTitle = title
  ? SITE_METADATA.title.template.replace("%s", title)
  : SITE_METADATA.title.default;
const finalDescription = description || SITE_METADATA.description;
const finalImage = image || SITE_METADATA.openGraph.images[0].url;
const imageURL = new URL(finalImage, Astro.site);

const structuredData = [ORGANIZATION_JSONLD, ...jsonLd];
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />

<!-- Self-hosted fonts preloaded (no external font requests) -->
<link
  rel="preload"
  href="/fonts/dm-sans/DMSans-Regular.woff2"
  as="font"
  type="font/woff2"
  crossorigin="anonymous"
/>
<link
  rel="preload"
  href="/fonts/dm-sans/DMSans-Medium.woff2"
  as="font"
  type="font/woff2"
  crossorigin="anonymous"
/>
<link
  rel="preload"
  href="/fonts/dm-sans/DMSans-SemiBold.woff2"
  as="font"
  type="font/woff2"
  crossorigin="anonymous"
/>

<meta
  name="robots"
  content={noindex
    ? "noindex, nofollow"
    : `${SITE_METADATA.robots.index ? "index" : "noindex"}, ${SITE_METADATA.robots.follow ? "follow" : "nofollow"}`}
/>
<meta name="author" content={SITE_METADATA.authors[0].name} />
<meta name="theme-color" content="#0B1726" />

<!-- Mark JS available (before paint, so scroll-reveal has no flash) and set up
     a subtle reveal-on-scroll for [data-reveal] blocks. -->
<script is:inline>
  document.documentElement.classList.add("js");
  (function () {
    function run() {
      var els = document.querySelectorAll("[data-reveal]");
      if (!("IntersectionObserver" in window)) {
        els.forEach(function (e) {
          e.classList.add("is-visible");
        });
        return;
      }
      var io = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add("is-visible");
              io.unobserve(e.target);
            }
          });
        },
        { rootMargin: "0px 0px -8% 0px", threshold: 0.08 },
      );
      els.forEach(function (e) {
        io.observe(e);
      });
    }
    if (document.readyState !== "loading") run();
    else document.addEventListener("DOMContentLoaded", run);
  })();
</script>

<!-- Favicons (MeasuredPlan datum mark) -->
{
  SITE_METADATA.icons.icon.map((icon) => (
    <link rel="icon" type={icon.type} sizes={icon.sizes} href={icon.url} />
  ))
}
{
  SITE_METADATA.icons.apple.map((icon) => (
    <link rel="apple-touch-icon" sizes={icon.sizes} href={icon.url} />
  ))
}
<link rel="manifest" href="/site.webmanifest" />

<link rel="sitemap" href="/sitemap.xml" />
<meta name="generator" content={Astro.generator} />
<link rel="canonical" href={canonicalURL} />

<!-- Primary meta -->
<title>{finalTitle}</title>
<meta name="title" content={finalTitle} />
<meta name="description" content={finalDescription} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:site_name" content={SITE_METADATA.openGraph.siteName} />
<meta property="og:title" content={finalTitle} />
<meta property="og:description" content={finalDescription} />
<meta property="og:image" content={imageURL} />
<meta
  property="og:image:width"
  content={SITE_METADATA.openGraph.images[0].width.toString()}
/>
<meta
  property="og:image:height"
  content={SITE_METADATA.openGraph.images[0].height.toString()}
/>
<meta property="og:image:alt" content={SITE_METADATA.openGraph.images[0].alt} />

<!-- Twitter -->
<meta property="twitter:card" content={SITE_METADATA.twitter.card} />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={finalTitle} />
<meta property="twitter:description" content={finalDescription} />
<meta property="twitter:image" content={imageURL} />

<!-- Structured data -->
{
  structuredData.map((data) => (
    <script
      type="application/ld+json"
      set:html={JSON.stringify(data)}
      is:inline
    />
  ))
}

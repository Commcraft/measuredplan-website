---
// Global <head>. Imported once via DefaultLayout so global.css loads everywhere.
import "../styles/global.css";
import {
  SITE_METADATA,
  ORGANIZATION_JSONLD,
  ANALYTICS,
  ANALYTICS_ENABLED,
} from "../consts";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  /** Extra JSON-LD objects for this page (Service, FAQPage, BreadcrumbList). */
  jsonLd?: Record<string, unknown>[];
  noindex?: boolean;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image, jsonLd = [], noindex = false } = Astro.props;
const finalTitle = title
  ? SITE_METADATA.title.template.replace("%s", title)
  : SITE_METADATA.title.default;
const finalDescription = description || SITE_METADATA.description;
const finalImage = image || SITE_METADATA.openGraph.images[0].url;
const imageURL = new URL(finalImage, Astro.site);

const structuredData = [ORGANIZATION_JSONLD, ...jsonLd];
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />

<!-- Content Security Policy (defense-in-depth). Allows only this origin plus
     the site's real third parties: Umami analytics, Web3Forms (contact form)
     and CARTO map tiles. 'unsafe-inline' is required for the site's inline
     scripts/styles; a static site has no server to issue nonces, and there is
     no user-generated HTML on the page, so the residual risk is low. Some
     directives (frame-ancestors, HSTS) can only be set as HTTP headers - do
     those at the CDN/Cloudflare layer. -->
<meta
  http-equiv="Content-Security-Policy"
  content="default-src 'self'; base-uri 'self'; object-src 'none'; script-src 'self' 'unsafe-inline' https://*.umami.is; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://*.basemaps.cartocdn.com; font-src 'self'; connect-src 'self' https://*.umami.is https://api.web3forms.com; form-action 'self' https://api.web3forms.com; frame-src 'none'; manifest-src 'self'"
/>

<!-- Self-hosted fonts preloaded (no external font requests) -->
<link
  rel="preload"
  href="/fonts/dm-sans/DMSans-Regular.woff2"
  as="font"
  type="font/woff2"
  crossorigin="anonymous"
/>
<link
  rel="preload"
  href="/fonts/dm-sans/DMSans-Medium.woff2"
  as="font"
  type="font/woff2"
  crossorigin="anonymous"
/>
<link
  rel="preload"
  href="/fonts/dm-sans/DMSans-SemiBold.woff2"
  as="font"
  type="font/woff2"
  crossorigin="anonymous"
/>

<meta
  name="robots"
  content={noindex
    ? "noindex, nofollow"
    : `${SITE_METADATA.robots.index ? "index" : "noindex"}, ${SITE_METADATA.robots.follow ? "follow" : "nofollow"}`}
/>
<meta name="author" content={SITE_METADATA.authors[0].name} />
<meta name="theme-color" content="#0B1726" />

<!-- Privacy-friendly analytics (Umami) - free, open source, no cookies, no
     consent banner. Loads only once a real Website ID is configured. -->
{
  ANALYTICS_ENABLED && (
    <script
      defer
      src={ANALYTICS.src}
      data-website-id={ANALYTICS.websiteId}
      is:inline
    />
  )
}

<!-- Mark JS available (before paint, so scroll-reveal has no flash) and set up
     a subtle reveal-on-scroll for [data-reveal] blocks. -->
<script is:inline>
  document.documentElement.classList.add("js");
  (function () {
    // Reveal any not-yet-revealed block whose top has entered the viewport.
    // Uses layout geometry, so it works even inside content-visibility:auto
    // sections where IntersectionObserver can fail to fire on some engines.
    function revealInView() {
      var vh = window.innerHeight || document.documentElement.clientHeight;
      var els = document.querySelectorAll("[data-reveal]:not(.is-visible)");
      for (var i = 0; i < els.length; i++) {
        // Reveal as soon as the top edge has entered the viewport (or is above
        // it). No lower bound, so nothing is ever left faded after a fast scroll.
        if (els[i].getBoundingClientRect().top < vh) els[i].classList.add("is-visible");
      }
    }
    function run() {
      var els = document.querySelectorAll("[data-reveal]");
      if (!("IntersectionObserver" in window)) {
        for (var i = 0; i < els.length; i++) els[i].classList.add("is-visible");
        return;
      }
      var io = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add("is-visible");
              io.unobserve(e.target);
            }
          });
        },
        { rootMargin: "0px 0px -8% 0px", threshold: 0.08 },
      );
      els.forEach(function (e) {
        io.observe(e);
      });
      // Geometry fallback: guarantees content is never left invisible if IO
      // misses an element (notably inside content-visibility:auto sections).
      var ticking = false;
      function onScroll() {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(function () {
          revealInView();
          ticking = false;
        });
      }
      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("resize", onScroll, { passive: true });
      revealInView();
      window.addEventListener("load", function () {
        setTimeout(revealInView, 200);
      });
    }
    if (document.readyState !== "loading") run();
    else document.addEventListener("DOMContentLoaded", run);
  })();
</script>

<!-- Favicons (MeasuredPlan datum mark) -->
{
  SITE_METADATA.icons.icon.map((icon) => (
    <link rel="icon" type={icon.type} sizes={icon.sizes} href={icon.url} />
  ))
}
{
  SITE_METADATA.icons.apple.map((icon) => (
    <link rel="apple-touch-icon" sizes={icon.sizes} href={icon.url} />
  ))
}
<link rel="manifest" href="/site.webmanifest" />

<link rel="sitemap" href="/sitemap.xml" />
<meta name="generator" content={Astro.generator} />
<link rel="canonical" href={canonicalURL} />

<!-- Primary meta -->
<title>{finalTitle}</title>
<meta name="title" content={finalTitle} />
<meta name="description" content={finalDescription} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:site_name" content={SITE_METADATA.openGraph.siteName} />
<meta property="og:title" content={finalTitle} />
<meta property="og:description" content={finalDescription} />
<meta property="og:image" content={imageURL} />
<meta
  property="og:image:width"
  content={SITE_METADATA.openGraph.images[0].width.toString()}
/>
<meta
  property="og:image:height"
  content={SITE_METADATA.openGraph.images[0].height.toString()}
/>
<meta property="og:image:alt" content={SITE_METADATA.openGraph.images[0].alt} />

<!-- Twitter -->
<meta property="twitter:card" content={SITE_METADATA.twitter.card} />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={finalTitle} />
<meta property="twitter:description" content={finalDescription} />
<meta property="twitter:image" content={imageURL} />

<!-- Structured data -->
{
  structuredData.map((data) => (
    <script
      type="application/ld+json"
      set:html={JSON.stringify(data)}
      is:inline
    />
  ))
}

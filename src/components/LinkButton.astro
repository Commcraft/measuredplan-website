---
// The single button system for the site. Renders an <a> when `href` is set,
// otherwise a <button>. Variants and sizes are the only allowed button styles.
type Variant = "primary" | "outline" | "ghost";
type Size = "sm" | "md" | "lg";

interface Props {
  href?: string;
  variant?: Variant;
  size?: Size;
  type?: "button" | "submit" | "reset";
  class?: string;
  disabled?: boolean;
  [key: string]: unknown;
}

const {
  href,
  variant = "primary",
  size = "md",
  type = "button",
  class: className = "",
  disabled = false,
  ...rest
} = Astro.props;

const base =
  "inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md " +
  "font-medium transition-colors duration-150 focus-visible:outline-none " +
  "disabled:opacity-50 disabled:pointer-events-none [&_svg]:size-4 [&_svg]:shrink-0";

const variants: Record<Variant, string> = {
  // Red - the single primary action. On .band-ink, --primary becomes red-inverse.
  primary: "bg-primary text-primary-foreground hover:bg-red-deep",
  // Architectural outline - ink hairline that fills on hover.
  outline:
    "border border-ink/70 text-ink bg-transparent hover:bg-ink hover:text-paper " +
    "band-ink:border-paper/60 band-ink:text-paper band-ink:hover:bg-paper band-ink:hover:text-ink",
  ghost: "text-ink hover:bg-stone band-ink:text-paper band-ink:hover:bg-white/10",
};

const sizes: Record<Size, string> = {
  sm: "h-9 px-4 text-sm",
  md: "h-11 px-6 text-[0.9375rem]",
  lg: "h-12 px-7 text-base",
};

const cls = [base, variants[variant], sizes[size], className];
const Tag = href ? "a" : "button";
---

<Tag
  class:list={cls}
  href={href}
  type={href ? undefined : type}
  aria-disabled={disabled ? "true" : undefined}
  {...rest}
>
  <slot />
</Tag>

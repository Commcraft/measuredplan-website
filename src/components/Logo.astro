---
// Official MeasuredPlan wordmark (Satoshi Semibold lockup, from the logo pack).
// The SVGs are fully outlined — no font dependency — and used unmodified.
//   ink   → header wordmark (dark text, for light surfaces)
//   paper → reversed wordmark (paper text, for dark .band-ink surfaces)
interface Props {
  tone?: "ink" | "paper";
  href?: string | null;
  class?: string;
}
const { tone = "ink", href = "/", class: className = "" } = Astro.props;

const src =
  tone === "paper"
    ? "/brand/measuredplan-logo-wordmark-paper.svg"
    : "/brand/measuredplan-logo-header.svg";
const Tag = href ? "a" : "span";
---

<Tag
  href={href ?? undefined}
  class:list={["inline-flex items-center rounded-sm", className]}
  aria-label="MeasuredPlan — home"
>
  <img
    src={src}
    alt="MeasuredPlan"
    width="220"
    height="27.5"
    class="h-[22px] w-auto sm:h-6"
  />
</Tag>

---
// Official MeasuredPlan primary lockup (wordmark + ruler + red datum), from the
// logo pack, inlined so the "d" glyph can animate. On hover the "d" makes one
// full turn - and because "d" rotated 180 degrees IS "p", the spin reveals the
// dP symmetry in the name (a small brand-memory flourish). The wordmark always
// resolves back to "d", so the logo is never shown distorted at rest.
import { readFileSync } from "node:fs";

interface Props {
  tone?: "ink" | "paper";
  href?: string | null;
  class?: string;
}
const { tone = "ink", href = "/", class: className = "" } = Astro.props;

const file =
  tone === "paper"
    ? "public/brand/measuredplan-logo-primary-reversed.svg"
    : "public/brand/measuredplan-logo-primary.svg";

let svg = readFileSync(file, "utf8");
// The "dP" ligature draws the "d" last, as the 12th (clipped) glyph path.
// Wrap it so it can spin on hover. Its clip-path is a full-bounds export
// artifact - remove it so the glyph isn't cut while it rotates.
svg = svg.replace(/ clip-path="url\(#cp-primary[^)]*\)"/g, "");
// Glyph paths in order: the 8th is the "P", the 12th (drawn last) is the "d".
let n = 0;
svg = svg.replace(/<path\b/g, (m) => {
  n += 1;
  if (n === 8) return '<path class="mp-p"';
  if (n === 12) return '<path class="mp-d"';
  return m;
});
// The red datum square (unique x) - it pulses between the flipping d and P.
svg = svg.replace('<rect x="4377.1"', '<rect class="mp-datum" x="4377.1"');
// size + a11y hooks on the root svg
svg = svg.replace(
  "<svg ",
  '<svg class="mp-logo-svg h-8 w-auto sm:h-9" aria-hidden="true" focusable="false" ',
);

const Tag = href ? "a" : "span";
---

<Tag
  href={href ?? undefined}
  class:list={["mp-logo inline-flex items-center", className]}
  aria-label="MeasuredPlan - home"
>
  <Fragment set:html={svg} />
</Tag>

<style is:global>
  /* Global (not scoped): these target glyphs injected via set:html, which
     Astro's style scoping does not reach. The "d" and "P" do a synchronised
     vertical flip (a coin-flip that goes edge-on at the midpoint, hiding any
     glyph-height mismatch) in mirrored directions, so the dP pair reads as a
     mirror of itself. The red datum is cursor-driven (see script): it glides
     toward the pointer and lifts into the letter band, echoing the hero
     reticle, then eases back to an identical rest square. */
  .mp-logo-svg {
    perspective: 900px;
  }
  .mp-d,
  .mp-p,
  .mp-datum {
    transform-box: fill-box;
    transform-origin: center;
    will-change: transform;
  }
  @media (prefers-reduced-motion: no-preference) {
    .mp-logo:hover .mp-d,
    .mp-logo:focus-visible .mp-d {
      animation: mp-flip-a 1s cubic-bezier(0.55, 0, 0.3, 1);
    }
    .mp-logo:hover .mp-p,
    .mp-logo:focus-visible .mp-p {
      animation: mp-flip-b 1s cubic-bezier(0.55, 0, 0.3, 1);
    }
  }
  @keyframes mp-flip-a {
    to {
      transform: rotateX(360deg);
    }
  }
  @keyframes mp-flip-b {
    to {
      transform: rotateX(-360deg);
    }
  }
</style>

<script>
  // Cursor-driven red datum: while the pointer is over the logo, the datum
  // glides toward it (horizontally) and lifts into the letter band, rotating
  // toward a diamond and growing - the same reticle feel as the hero field.
  // On leave it eases back and the inline transform is cleared, so the logo is
  // pixel-identical at rest. Offsets are in the datum's own SVG units (which
  // are scale-independent), the same units the rest-state markup uses.
  (function () {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    const LIFT = 500; // SVG units the datum rises into the letter band
    const LEAN = 760; // max SVG units the datum leans toward the cursor

    document.querySelectorAll<HTMLElement>(".mp-logo").forEach((logo) => {
      const datum = logo.querySelector<SVGGraphicsElement>(".mp-datum");
      if (!datum) return;

      let engaged = 0; // eased 0..1
      let engagedT = 0; // engagement target
      let leanX = 0; // eased horizontal offset (SVG units)
      let leanT = 0; // horizontal target (SVG units)
      let raf = 0;

      function step() {
        engaged += (engagedT - engaged) * 0.2;
        leanX += (leanT - leanX) * 0.25;
        const k = engaged;
        if (engagedT === 0 && k < 0.01) {
          datum!.style.transform = ""; // exact rest - pixel-identical
          raf = 0;
          return;
        }
        const tx = leanX * k;
        const ty = LIFT * k; // rise into the letter band
        datum!.style.transform =
          `translate(${tx}px, ${ty}px) rotate(${45 * k}deg) scale(${1 + 0.5 * k})`;
        raf = requestAnimationFrame(step);
      }
      function start() {
        if (!raf) raf = requestAnimationFrame(step);
      }

      logo.addEventListener("pointerenter", (e) => {
        if (e.pointerType === "touch") return;
        engagedT = 1;
        start();
      });
      logo.addEventListener(
        "pointermove",
        (e) => {
          if (e.pointerType === "touch") return;
          const r = logo.getBoundingClientRect();
          const nx = Math.max(
            -1,
            Math.min(1, ((e.clientX - r.left) / r.width) * 2 - 1),
          );
          leanT = nx * LEAN; // -1..1 across the logo
          start();
        },
        { passive: true },
      );
      logo.addEventListener("pointerleave", (e) => {
        if (e.pointerType === "touch") return;
        engagedT = 0;
        leanT = 0;
        start();
      });
    });
  })();
</script>

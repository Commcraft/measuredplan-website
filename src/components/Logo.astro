---
// Official MeasuredPlan primary lockup (Satoshi wordmark + ruler + red datum),
// from the logo pack. Fully outlined SVG — no font dependency — used unmodified.
//   ink   → primary lockup (dark, for light surfaces)
//   paper → reversed primary lockup (for dark .band-ink surfaces)
interface Props {
  tone?: "ink" | "paper";
  href?: string | null;
  class?: string;
}
const { tone = "ink", href = "/", class: className = "" } = Astro.props;

const src =
  tone === "paper"
    ? "/brand/measuredplan-logo-primary-reversed.svg"
    : "/brand/measuredplan-logo-primary.svg";
const Tag = href ? "a" : "span";
---

<Tag
  href={href ?? undefined}
  class:list={["inline-flex items-center rounded-sm", className]}
  aria-label="MeasuredPlan — home"
>
  <img
    src={src}
    alt="MeasuredPlan"
    width="520"
    height="85.6"
    class="h-8 w-auto sm:h-9"
  />
</Tag>

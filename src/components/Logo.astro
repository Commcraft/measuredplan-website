---
// Official MeasuredPlan primary lockup (wordmark + ruler + red datum), from the
// logo pack, inlined so the "d" glyph can animate. On hover the "d" makes one
// full turn - and because "d" rotated 180 degrees IS "p", the spin reveals the
// dP symmetry in the name (a small brand-memory flourish). The wordmark always
// resolves back to "d", so the logo is never shown distorted at rest.
import { readFileSync } from "node:fs";

interface Props {
  tone?: "ink" | "paper";
  href?: string | null;
  class?: string;
  /** Render as a plain <img> (cacheable, no hover animation). Use in the
      footer so the heavy lockup SVG isn't inlined twice per page. */
  img?: boolean;
}
const {
  tone = "ink",
  href = "/",
  class: className = "",
  img = false,
} = Astro.props;

const publicSrc =
  tone === "paper"
    ? "/brand/measuredplan-logo-primary-reversed.svg"
    : "/brand/measuredplan-logo-primary.svg";
const file = `public${publicSrc}`;

let svg = img ? "" : readFileSync(file, "utf8");
// The "dP" ligature draws the "d" last, as the 12th (clipped) glyph path.
// Wrap it so it can spin on hover. Its clip-path is a full-bounds export
// artifact - remove it so the glyph isn't cut while it rotates.
svg = svg.replace(/ clip-path="url\(#cp-primary[^)]*\)"/g, "");
// Glyph paths in order: the 8th is the "P", the 12th (drawn last) is the "d".
let n = 0;
svg = svg.replace(/<path\b/g, (m) => {
  n += 1;
  if (n === 8) return '<path class="mp-p"';
  if (n === 12) return '<path class="mp-d"';
  return m;
});
// size + a11y hooks on the root svg
svg = svg.replace(
  "<svg ",
  '<svg class="mp-logo-svg h-8 w-auto sm:h-9" aria-hidden="true" focusable="false" ',
);

const Tag = href ? "a" : "span";
---

<Tag
  href={href ?? undefined}
  class:list={["mp-logo inline-flex items-center", className]}
  aria-label="MeasuredPlan - home"
>
  {
    img ? (
      <img
        src={publicSrc}
        width="6232"
        height="1026"
        alt=""
        class="h-8 w-auto sm:h-9"
      />
    ) : (
      <Fragment set:html={svg} />
    )
  }
</Tag>

<style is:global>
  /* Global (not scoped): these target glyphs injected via set:html, which
     Astro's style scoping does not reach. On hover the "d" and "P" do a
     synchronised vertical flip (a coin-flip that goes edge-on at the midpoint,
     hiding any glyph-height mismatch) in mirrored directions, so the dP pair
     reads as a mirror of itself. The red datum stays put as the anchor. */
  .mp-logo-svg {
    perspective: 900px;
  }
  .mp-d,
  .mp-p {
    transform-box: fill-box;
    transform-origin: center;
    will-change: transform;
  }
  @media (prefers-reduced-motion: no-preference) {
    .mp-logo:hover .mp-d,
    .mp-logo:focus-visible .mp-d {
      animation: mp-flip-a 1s cubic-bezier(0.55, 0, 0.3, 1);
    }
    .mp-logo:hover .mp-p,
    .mp-logo:focus-visible .mp-p {
      animation: mp-flip-b 1s cubic-bezier(0.55, 0, 0.3, 1);
    }
  }
  /* Touch devices have no hover, so the dP flourish would never play. Run it
     once on load instead, shortly after the header appears. */
  @media (prefers-reduced-motion: no-preference) and (hover: none) {
    .mp-d {
      animation: mp-flip-a 1s cubic-bezier(0.55, 0, 0.3, 1) 0.6s;
    }
    .mp-p {
      animation: mp-flip-b 1s cubic-bezier(0.55, 0, 0.3, 1) 0.6s;
    }
  }
  @keyframes mp-flip-a {
    to {
      transform: rotateX(360deg);
    }
  }
  @keyframes mp-flip-b {
    to {
      transform: rotateX(-360deg);
    }
  }
</style>

---
// Official MeasuredPlan primary lockup (wordmark + ruler + red datum), from the
// logo pack, inlined so the "d" glyph can animate. On hover the "d" makes one
// full turn - and because "d" rotated 180 degrees IS "p", the spin reveals the
// dP symmetry in the name (a small brand-memory flourish). The wordmark always
// resolves back to "d", so the logo is never shown distorted at rest.
import { readFileSync } from "node:fs";

interface Props {
  tone?: "ink" | "paper";
  href?: string | null;
  class?: string;
}
const { tone = "ink", href = "/", class: className = "" } = Astro.props;

const file =
  tone === "paper"
    ? "public/brand/measuredplan-logo-primary-reversed.svg"
    : "public/brand/measuredplan-logo-primary.svg";

let svg = readFileSync(file, "utf8");
// The "dP" ligature draws the "d" last, as the 12th (clipped) glyph path.
// Wrap it so it can spin on hover. Its clip-path is a full-bounds export
// artifact - remove it so the glyph isn't cut while it rotates.
svg = svg.replace(/ clip-path="url\(#cp-primary[^)]*\)"/g, "");
// Glyph paths in order: the 8th is the "P", the 12th (drawn last) is the "d".
let n = 0;
svg = svg.replace(/<path\b/g, (m) => {
  n += 1;
  if (n === 8) return '<path class="mp-p"';
  if (n === 12) return '<path class="mp-d"';
  return m;
});
// The red datum square (unique x) - it pulses between the flipping d and P.
svg = svg.replace('<rect x="4377.1"', '<rect class="mp-datum" x="4377.1"');
// size + a11y hooks on the root svg
svg = svg.replace(
  "<svg ",
  '<svg class="mp-logo-svg h-8 w-auto sm:h-9" aria-hidden="true" focusable="false" ',
);

const Tag = href ? "a" : "span";
---

<Tag
  href={href ?? undefined}
  class:list={["mp-logo inline-flex items-center", className]}
  aria-label="MeasuredPlan - home"
>
  <Fragment set:html={svg} />
</Tag>

<style is:global>
  /* Global (not scoped): these target glyphs injected via set:html, which
     Astro's style scoping does not reach. The "d" and "P" do a synchronised
     vertical flip (a coin-flip that goes edge-on at the midpoint, hiding any
     glyph-height mismatch) in mirrored directions, so the dP pair reads as a
     mirror of itself. The red datum pulses between them. */
  .mp-logo-svg {
    perspective: 900px;
  }
  .mp-d,
  .mp-p,
  .mp-datum {
    transform-box: fill-box;
    transform-origin: center;
    will-change: transform;
  }
  @media (prefers-reduced-motion: no-preference) {
    .mp-logo:hover .mp-d,
    .mp-logo:focus-visible .mp-d {
      animation: mp-flip-a 1s cubic-bezier(0.55, 0, 0.3, 1);
    }
    .mp-logo:hover .mp-p,
    .mp-logo:focus-visible .mp-p {
      animation: mp-flip-b 1s cubic-bezier(0.55, 0, 0.3, 1);
    }
    .mp-logo:hover .mp-datum,
    .mp-logo:focus-visible .mp-datum {
      animation: mp-datum-turn 1s cubic-bezier(0.55, 0, 0.3, 1);
    }
  }
  @keyframes mp-flip-a {
    to {
      transform: rotateX(360deg);
    }
  }
  @keyframes mp-flip-b {
    to {
      transform: rotateX(-360deg);
    }
  }
  /* The "d" and "P" go edge-on (invisible) at 25% and 75% of their flip. On
     each of those beats the datum leaps up into the empty "dP" gap, spins, and
     grows - standing in for the missing letters - then drops home as they
     resolve. Two full turns over the second; ends exactly where it started. */
  @keyframes mp-datum-turn {
    0% {
      transform: translateY(0) rotate(0) scale(1);
    }
    25% {
      transform: translateY(500px) rotate(180deg) scale(1.8);
    }
    50% {
      transform: translateY(0) rotate(360deg) scale(1);
    }
    75% {
      transform: translateY(500px) rotate(540deg) scale(1.8);
    }
    100% {
      transform: translateY(0) rotate(720deg) scale(1);
    }
  }
</style>

---
// Original measured-plan hero visual. Pure SVG, no imagery, lightweight.
// Thin technical linework, double-line walls, dimension strings, a scale note,
// a title block, and exactly one red datum marker.
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
const ink = "#0B1726";
const line = "#838D97";
const dim = "#5F6973";
const red = "#C21F3A";
const paper = "#F7F5F0";
---

<figure
  class:list={[
    "title-block overflow-hidden",
    className,
  ]}
  aria-label="Measured floor-plan drawing showing dimensioned rooms, a scale note, a title block, and a datum reference marker."
  role="img"
>
  <svg
    viewBox="0 0 720 560"
    xmlns="http://www.w3.org/2000/svg"
    class="block h-auto w-full"
    style="font-family: ui-monospace, 'SF Mono', Menlo, monospace;"
  >
    <rect width="720" height="560" fill={paper}></rect>

    <!-- faint plan grid -->
    <g stroke={line} stroke-width="0.5" opacity="0.22">
      {
        Array.from({ length: 17 }).map((_, i) => (
          <line x1={40 + i * 40} y1="40" x2={40 + i * 40} y2="520" />
        ))
      }
      {
        Array.from({ length: 13 }).map((_, i) => (
          <line x1="40" y1={40 + i * 40} x2="680" y2={40 + i * 40} />
        ))
      }
    </g>

    <!-- sheet frame -->
    <rect
      x="16"
      y="16"
      width="688"
      height="528"
      fill="none"
      stroke={line}
      stroke-width="1"></rect>

    <!-- ===== walls (double line) ===== -->
    <g stroke={ink} fill="none" stroke-width="2" stroke-linejoin="miter">
      <!-- outer -->
      <rect x="120" y="110" width="440" height="300"></rect>
      <rect x="130" y="120" width="420" height="280"></rect>
    </g>
    <!-- internal partitions (double line) -->
    <g stroke={ink} stroke-width="1.6">
      <line x1="360" y1="120" x2="360" y2="400"></line>
      <line x1="370" y1="120" x2="370" y2="400"></line>
      <line x1="370" y1="270" x2="550" y2="270"></line>
      <line x1="370" y1="280" x2="550" y2="280"></line>
    </g>

    <!-- door openings + swing arcs -->
    <g stroke={ink} stroke-width="1.4" fill="none">
      <!-- door between living and bedroom -->
      <path d="M360 175 A 45 45 0 0 1 365 220" stroke-width="1"></path>
      <line x1="360" y1="175" x2="360" y2="130" stroke={paper} stroke-width="4"
      ></line>
      <!-- door to bath -->
      <path d="M455 280 A 34 34 0 0 0 455 314" stroke-width="1"></path>
    </g>

    <!-- window breaks on outer wall (three thin lines) -->
    <g stroke={line} stroke-width="1">
      <line x1="200" y1="113" x2="200" y2="117"></line>
      <line x1="215" y1="115" x2="290" y2="115"></line>
      <line x1="305" y1="113" x2="305" y2="117"></line>
    </g>

    <!-- ===== dimension strings ===== -->
    <g stroke={line} stroke-width="1" fill={dim} font-size="12">
      <!-- top overall -->
      <line x1="120" y1="78" x2="560" y2="78"></line>
      <g stroke-width="1.4">
        <line x1="120" y1="72" x2="120" y2="84"></line>
        <line x1="365" y1="72" x2="365" y2="84"></line>
        <line x1="560" y1="72" x2="560" y2="84"></line>
      </g>
      <text x="242" y="70" text-anchor="middle">14'-0"</text>
      <text x="462" y="70" text-anchor="middle">12'-6"</text>

      <!-- left overall -->
      <line x1="92" y1="110" x2="92" y2="410"></line>
      <g stroke-width="1.4">
        <line x1="86" y1="110" x2="98" y2="110"></line>
        <line x1="86" y1="410" x2="98" y2="410"></line>
      </g>
      <text
        x="80"
        y="264"
        text-anchor="middle"
        transform="rotate(-90 80 264)">18'-0"</text
      >
    </g>

    <!-- room labels -->
    <g fill={ink} font-size="12.5" letter-spacing="0.06em">
      <text x="160" y="250">LIVING / KITCHEN</text>
      <text x="160" y="268" fill={dim} font-size="11">245 SF</text>
      <text x="405" y="190">BEDROOM</text>
      <text x="405" y="208" fill={dim} font-size="11">150 SF</text>
      <text x="405" y="330">BATH</text>
    </g>

    <!-- north point -->
    <g transform="translate(628 118)">
      <circle r="16" fill="none" stroke={line} stroke-width="1"></circle>
      <path d="M0 -16 L4 2 L0 -3 L-4 2 Z" fill={ink}></path>
      <text x="0" y="30" text-anchor="middle" fill={dim} font-size="10">N</text>
    </g>

    <!-- ===== scale note ===== -->
    <g transform="translate(120 452)">
      <text fill={ink} font-size="11" letter-spacing="0.08em">
        SCALE: 1/4" = 1'-0"
      </text>
      <g transform="translate(0 12)" stroke={ink} stroke-width="1">
        <line x1="0" y1="8" x2="120" y2="8"></line>
        <line x1="0" y1="4" x2="0" y2="12"></line>
        <line x1="40" y1="4" x2="40" y2="12"></line>
        <line x1="80" y1="4" x2="80" y2="12"></line>
        <line x1="120" y1="4" x2="120" y2="12"></line>
        <rect x="0" y="4" width="40" height="8" fill={ink}></rect>
        <rect x="80" y="4" width="40" height="8" fill={ink}></rect>
      </g>
      <text fill={dim} font-size="9" y="34">0</text>
      <text fill={dim} font-size="9" y="34" x="110">8'</text>
    </g>

    <!-- ===== title block ===== -->
    <g transform="translate(430 440)">
      <rect
        width="258"
        height="88"
        fill="none"
        stroke={ink}
        stroke-width="1"></rect>
      <line x1="0" y1="30" x2="258" y2="30" stroke={ink} stroke-width="1"></line>
      <line x1="0" y1="59" x2="258" y2="59" stroke={ink} stroke-width="1"></line>
      <line x1="170" y1="59" x2="170" y2="88" stroke={ink} stroke-width="1"
      ></line>
      <text x="10" y="20" fill={ink} font-size="12" letter-spacing="0.1em"
        >MEASUREDPLAN</text
      >
      <text x="10" y="49" fill={dim} font-size="10"
        >EXISTING - GROUND FLOOR</text
      >
      <text x="10" y="78" fill={dim} font-size="10">SHEET 01 / 04</text>
      <text x="180" y="78" fill={dim} font-size="10">REV A</text>
    </g>

    <!-- ===== single red datum marker ===== -->
    <g>
      <line x1="120" y1="410" x2="120" y2="432" stroke={red} stroke-width="1"
      ></line>
      <line x1="108" y1="420" x2="132" y2="420" stroke={red} stroke-width="1"
      ></line>
      <rect x="114" y="414" width="12" height="12" fill={red}></rect>
      <text x="138" y="425" fill={red} font-size="11" letter-spacing="0.08em"
        >DATUM</text
      >
    </g>
  </svg>
</figure>

---
// Hero cursor: a single precise red datum mark (with a thin ring) that tracks
// the pointer 1:1 - no crosshair lines, no background grid. Drawn from the live
// pointer position so there is no lag; repaints only while the pointer moves
// over the hero, so it is idle-cheap. Inert to assistive tech; honours reduced
// motion (then it does not draw).
---

<canvas
  data-hero-field
  class="pointer-events-none absolute inset-0 h-full w-full"
  aria-hidden="true"></canvas>

<script>
  const canvas =
    document.querySelector<HTMLCanvasElement>("[data-hero-field]");
  const host = canvas?.closest("section") as HTMLElement | null;
  const ctx = canvas?.getContext("2d") ?? null;

  if (canvas && host && ctx) {
    const g = ctx;
    const cv = canvas;
    const hs = host;
    const reduce = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const INK = "11,23,38"; // --mp-ink
    const RED = "194,31,58"; // --mp-red
    const dpr = Math.min(window.devicePixelRatio || 1, 2);

    let w = 0;
    let h = 0;
    let raf = 0;
    const pointer = { x: 0, y: 0, active: false };

    function resize() {
      const r = hs.getBoundingClientRect();
      w = r.width;
      h = r.height;
      cv.width = Math.round(w * dpr);
      cv.height = Math.round(h * dpr);
      g.setTransform(dpr, 0, 0, dpr, 0, 0);
      draw();
    }

    function draw() {
      g.clearRect(0, 0, w, h);
      if (!pointer.active || reduce) return;
      const x = Math.round(pointer.x) + 0.5;
      const y = Math.round(pointer.y) + 0.5;
      // thin ring
      g.strokeStyle = `rgba(${INK},0.28)`;
      g.lineWidth = 1;
      g.strokeRect(x - 5, y - 5, 10, 10);
      // red datum square
      g.fillStyle = `rgba(${RED},0.95)`;
      g.fillRect(x - 2, y - 2, 4, 4);
    }

    function schedule() {
      if (!raf) raf = requestAnimationFrame(() => ((raf = 0), draw()));
    }

    if (!reduce) {
      hs.addEventListener(
        "pointermove",
        (e) => {
          if (e.pointerType === "touch") return;
          const r = hs.getBoundingClientRect();
          pointer.x = e.clientX - r.left;
          pointer.y = e.clientY - r.top;
          pointer.active = true;
          schedule();
        },
        { passive: true },
      );
      hs.addEventListener("pointerleave", () => {
        pointer.active = false;
        schedule();
      });
    }

    new ResizeObserver(resize).observe(hs);
    resize();
  }
</script>

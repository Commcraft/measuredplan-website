---
// Decorative hero backdrop: a faint, static "survey sheet" grid of crosshair
// ticks - a quiet nod to the drafting behind the work. The ticks nearest the
// cursor brighten softly, and a small survey reticle (gapped crosshair + red
// datum) locks to the pointer, tracking it 1:1. It repaints only while the
// pointer is moving over the hero, so it is idle-cheap. Inert to assistive
// tech; honours reduced motion (then it is purely static, no reticle).
---

<canvas
  data-hero-field
  class="pointer-events-none absolute inset-0 h-full w-full"
  aria-hidden="true"></canvas>

<script>
  const canvas =
    document.querySelector<HTMLCanvasElement>("[data-hero-field]");
  const host = canvas?.closest("section") as HTMLElement | null;
  const ctx = canvas?.getContext("2d") ?? null;

  if (canvas && host && ctx) {
    const g = ctx;
    const cv = canvas;
    const hs = host;
    const reduce = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const INK = "11,23,38"; // --mp-ink
    const RED = "194,31,58"; // --mp-red
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const GRID = 60; // tick spacing (CSS px)
    const R = 150; // spotlight radius (CSS px)
    const BASE = 0.05; // resting tick opacity
    const BOOST = 0.22; // extra opacity at the cursor

    let w = 0;
    let h = 0;
    let raf = 0;
    const pointer = { x: -9999, y: -9999, active: false };

    function resize() {
      const r = hs.getBoundingClientRect();
      w = r.width;
      h = r.height;
      cv.width = Math.round(w * dpr);
      cv.height = Math.round(h * dpr);
      g.setTransform(dpr, 0, 0, dpr, 0, 0);
      draw();
    }

    function draw() {
      g.clearRect(0, 0, w, h);
      const spot = pointer.active && !reduce;
      const r2 = R * R;
      for (let x = GRID; x < w; x += GRID) {
        for (let y = GRID; y < h; y += GRID) {
          let a = BASE;
          if (spot) {
            const dx = x - pointer.x;
            const dy = y - pointer.y;
            const d2 = dx * dx + dy * dy;
            if (d2 < r2) {
              const f = 1 - Math.sqrt(d2) / R; // 1 at cursor -> 0 at edge
              a = BASE + BOOST * f * f;
            }
          }
          g.strokeStyle = `rgba(${INK},${a})`;
          g.lineWidth = 1;
          g.beginPath();
          g.moveTo(x - 3, y);
          g.lineTo(x + 3, y);
          g.moveTo(x, y - 3);
          g.lineTo(x, y + 3);
          g.stroke();
        }
      }
      if (spot) drawReticle();
    }

    // A small survey reticle locked exactly to the pointer: a gapped crosshair
    // (short arms, so it never lines out across the text) and a red datum at
    // its centre. Drawn from the live pointer, so it tracks 1:1 with no lag.
    function drawReticle() {
      const x = Math.round(pointer.x) + 0.5;
      const y = Math.round(pointer.y) + 0.5;
      g.strokeStyle = `rgba(${INK},0.5)`;
      g.lineWidth = 1;
      g.beginPath();
      g.moveTo(x - 11, y);
      g.lineTo(x - 4, y);
      g.moveTo(x + 4, y);
      g.lineTo(x + 11, y);
      g.moveTo(x, y - 11);
      g.lineTo(x, y - 4);
      g.moveTo(x, y + 4);
      g.lineTo(x, y + 11);
      g.stroke();
      g.strokeStyle = `rgba(${INK},0.28)`;
      g.strokeRect(x - 4.5, y - 4.5, 9, 9);
      g.fillStyle = `rgba(${RED},0.95)`;
      g.fillRect(x - 1.5, y - 1.5, 3, 3);
    }

    function schedule() {
      if (!raf) raf = requestAnimationFrame(() => ((raf = 0), draw()));
    }

    if (!reduce) {
      hs.addEventListener(
        "pointermove",
        (e) => {
          if (e.pointerType === "touch") return;
          const r = hs.getBoundingClientRect();
          pointer.x = e.clientX - r.left;
          pointer.y = e.clientY - r.top;
          pointer.active = true;
          schedule();
        },
        { passive: true },
      );
      hs.addEventListener("pointerleave", () => {
        pointer.active = false;
        schedule();
      });
    }

    new ResizeObserver(resize).observe(hs);
    resize();
  }
</script>

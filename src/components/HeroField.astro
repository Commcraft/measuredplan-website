---
// Decorative hero "survey field": a faint drift of survey marks (crosshair
// ticks and red datum squares) plus a cursor-following snap crosshair with a
// live coordinate readout - a small nod to the survey instruments behind the
// work. Purely decorative and inert to assistive tech; honours reduced motion
// and pauses when scrolled out of view.
---

<canvas
  data-hero-field
  class="pointer-events-none absolute inset-0 h-full w-full"
  aria-hidden="true"></canvas>

<script>
  const canvas =
    document.querySelector<HTMLCanvasElement>("[data-hero-field]");
  const host = canvas?.closest("section") as HTMLElement | null;
  const ctx = canvas?.getContext("2d") ?? null;

  if (canvas && host && ctx) {
    const g = ctx;
    const cv = canvas;
    const hs = host;
    const reduce = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const INK = "11,23,38"; // --mp-ink
    const RED = "194,31,58"; // --mp-red
    const dpr = Math.min(window.devicePixelRatio || 1, 2);

    let w = 0;
    let h = 0;
    let raf = 0;
    let visible = true;
    type Mark = {
      x: number;
      y: number;
      vx: number;
      vy: number;
      s: number;
      red: boolean;
      a: number;
    };
    let marks: Mark[] = [];
    const pointer = { x: 0, y: 0, active: false };

    function seed() {
      const count = Math.max(10, Math.min(26, Math.round((w * h) / 46000)));
      marks = Array.from({ length: count }, () => ({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.1,
        vy: -0.05 - Math.random() * 0.12,
        s: 4 + Math.random() * 5,
        red: Math.random() < 0.16,
        a: 0.05 + Math.random() * 0.1,
      }));
    }

    function resize() {
      const r = hs.getBoundingClientRect();
      w = r.width;
      h = r.height;
      cv.width = Math.round(w * dpr);
      cv.height = Math.round(h * dpr);
      g.setTransform(dpr, 0, 0, dpr, 0, 0);
      seed();
    }

    function drawMark(m: Mark) {
      if (m.red) {
        g.fillStyle = `rgba(${RED},${m.a + 0.06})`;
        const q = m.s / 3;
        g.fillRect(m.x - q, m.y - q, q * 2, q * 2);
      } else {
        g.strokeStyle = `rgba(${INK},${m.a})`;
        g.lineWidth = 1;
        g.beginPath();
        g.moveTo(m.x - m.s, m.y);
        g.lineTo(m.x + m.s, m.y);
        g.moveTo(m.x, m.y - m.s);
        g.lineTo(m.x, m.y + m.s);
        g.stroke();
      }
    }

    function drawPointer() {
      if (!pointer.active) return;
      const { x, y } = pointer;
      g.strokeStyle = `rgba(${INK},0.26)`;
      g.lineWidth = 1;
      g.beginPath();
      g.moveTo(0, y + 0.5);
      g.lineTo(w, y + 0.5);
      g.moveTo(x + 0.5, 0);
      g.lineTo(x + 0.5, h);
      g.stroke();
      g.strokeStyle = `rgba(${RED},0.9)`;
      g.strokeRect(x - 4, y - 4, 8, 8);

      const label = `x ${Math.round(x)}  y ${Math.round(y)}`;
      g.font =
        "11px ui-monospace, SFMono-Regular, Menlo, Consolas, monospace";
      const tw = g.measureText(label).width;
      let lx = x + 12;
      let ly = y + 20;
      if (lx + tw + 8 > w) lx = x - tw - 16;
      if (ly + 8 > h) ly = y - 12;
      g.fillStyle = `rgba(${INK},0.92)`;
      g.fillRect(lx - 5, ly - 12, tw + 10, 17);
      g.fillStyle = "rgba(247,245,240,0.96)";
      g.fillText(label, lx, ly);
    }

    function render() {
      g.clearRect(0, 0, w, h);
      for (const m of marks) drawMark(m);
      drawPointer();
    }

    function tick() {
      for (const m of marks) {
        m.x += m.vx;
        m.y += m.vy;
        if (m.y < -12) {
          m.y = h + 12;
          m.x = Math.random() * w;
        }
        if (m.x < -12) m.x = w + 12;
        else if (m.x > w + 12) m.x = -12;
      }
      render();
      raf = requestAnimationFrame(tick);
    }

    function play() {
      if (reduce) {
        render();
        return;
      }
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(tick);
    }
    function pause() {
      cancelAnimationFrame(raf);
    }

    hs.addEventListener("pointermove", (e) => {
      if (e.pointerType === "touch") return;
      const r = hs.getBoundingClientRect();
      pointer.x = e.clientX - r.left;
      pointer.y = e.clientY - r.top;
      pointer.active = true;
      if (reduce) render();
    });
    hs.addEventListener("pointerleave", () => {
      pointer.active = false;
      if (reduce) render();
    });

    new ResizeObserver(() => {
      resize();
      if (reduce || !visible) render();
    }).observe(hs);

    new IntersectionObserver(
      ([entry]) => {
        visible = entry.isIntersecting;
        if (!reduce) visible ? play() : pause();
      },
      { threshold: 0 },
    ).observe(hs);

    resize();
    play();
  }
</script>

---
// Decorative hero backdrop: a faint, static "survey sheet" grid of crosshair
// ticks - a quiet nod to the drafting behind the work. No motion, no pointer
// interaction, nothing red behind the text; purely texture and inert to
// assistive tech. Rendered as a single inline SVG pattern (no JS, no paint
// cost after first render).
---

<svg
  class="pointer-events-none absolute inset-0 h-full w-full"
  aria-hidden="true"
  focusable="false"
>
  <defs>
    <pattern
      id="mp-hero-grid"
      width="60"
      height="60"
      patternUnits="userSpaceOnUse"
    >
      <path
        d="M30 26 V34 M26 30 H34"
        stroke="rgba(11,23,38,0.06)"
        stroke-width="1"
        fill="none"></path>
    </pattern>
  </defs>
  <rect width="100%" height="100%" fill="url(#mp-hero-grid)"></rect>
</svg>

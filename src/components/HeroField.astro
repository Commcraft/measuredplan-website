---
// Hero "survey field": a faint, static grid of crosshair ticks that stays put
// as texture, plus a cursor reticle - full crosshair lines with a red datum at
// the intersection - that tracks the pointer 1:1. The ticks nearest the cursor
// brighten softly. Drawn from the live pointer position so there is no lag, and
// it repaints only while the pointer moves, so it is idle-cheap. Inert to
// assistive tech; honours reduced motion (then it is a static grid, no reticle).
---

<canvas
  data-hero-field
  class="pointer-events-none absolute inset-0 h-full w-full"
  aria-hidden="true"></canvas>

<script>
  const canvas =
    document.querySelector<HTMLCanvasElement>("[data-hero-field]");
  const host = canvas?.closest("section") as HTMLElement | null;
  const ctx = canvas?.getContext("2d") ?? null;

  if (canvas && host && ctx) {
    const g = ctx;
    const cv = canvas;
    const hs = host;
    const reduce = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const INK = "11,23,38"; // --mp-ink
    const RED = "194,31,58"; // --mp-red
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const GRID = 60; // tick spacing (CSS px)
    const R = 150; // spotlight radius (CSS px)
    const BASE = 0.05; // resting tick opacity
    const BOOST = 0.22; // extra tick opacity at the cursor

    let w = 0;
    let h = 0;
    let raf = 0;
    const pointer = { x: 0, y: 0, active: false };

    function resize() {
      const r = hs.getBoundingClientRect();
      w = r.width;
      h = r.height;
      cv.width = Math.round(w * dpr);
      cv.height = Math.round(h * dpr);
      g.setTransform(dpr, 0, 0, dpr, 0, 0);
      draw();
    }

    function draw() {
      g.clearRect(0, 0, w, h);
      const spot = pointer.active && !reduce;
      const r2 = R * R;
      // faint grid of crosshair ticks (brighter near the cursor)
      for (let x = GRID; x < w; x += GRID) {
        for (let y = GRID; y < h; y += GRID) {
          let a = BASE;
          if (spot) {
            const dx = x - pointer.x;
            const dy = y - pointer.y;
            const d2 = dx * dx + dy * dy;
            if (d2 < r2) {
              const f = 1 - Math.sqrt(d2) / R;
              a = BASE + BOOST * f * f;
            }
          }
          g.strokeStyle = `rgba(${INK},${a})`;
          g.lineWidth = 1;
          g.beginPath();
          g.moveTo(x - 3, y);
          g.lineTo(x + 3, y);
          g.moveTo(x, y - 3);
          g.lineTo(x, y + 3);
          g.stroke();
        }
      }
      if (spot) drawReticle();
    }

    // full crosshair lines + a red datum square at the intersection, locked to
    // the live pointer (1:1, no lag)
    function drawReticle() {
      const x = Math.round(pointer.x) + 0.5;
      const y = Math.round(pointer.y) + 0.5;
      g.strokeStyle = `rgba(${INK},0.2)`;
      g.lineWidth = 1;
      g.beginPath();
      g.moveTo(0, y);
      g.lineTo(w, y);
      g.moveTo(x, 0);
      g.lineTo(x, h);
      g.stroke();
      g.strokeStyle = `rgba(${INK},0.32)`;
      g.strokeRect(x - 5, y - 5, 10, 10);
      g.fillStyle = `rgba(${RED},0.95)`;
      g.fillRect(x - 2, y - 2, 4, 4);
    }

    function schedule() {
      if (!raf) raf = requestAnimationFrame(() => ((raf = 0), draw()));
    }

    if (!reduce) {
      hs.addEventListener(
        "pointermove",
        (e) => {
          if (e.pointerType === "touch") return;
          const r = hs.getBoundingClientRect();
          pointer.x = e.clientX - r.left;
          pointer.y = e.clientY - r.top;
          pointer.active = true;
          schedule();
        },
        { passive: true },
      );
      hs.addEventListener("pointerleave", () => {
        pointer.active = false;
        schedule();
      });
    }

    new ResizeObserver(resize).observe(hs);
    resize();
  }
</script>

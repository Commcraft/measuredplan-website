---
// Decorative hero "survey field": a faint registered grid of crosshair ticks
// with a few red datum stations, plus a cursor reticle that snaps to the grid
// with a live coordinate readout - a small nod to the survey instruments behind
// the work. The red datums echo the logo: they sit still as squares and, on a
// slow measured cadence, register with a rotate-to-diamond + scale pulse, then
// return to rest. Nothing drifts or bounces. Purely decorative and inert to
// assistive tech; honours reduced motion and pauses when scrolled out of view.
---

<canvas
  data-hero-field
  class="pointer-events-none absolute inset-0 h-full w-full"
  aria-hidden="true"></canvas>

<script>
  const canvas =
    document.querySelector<HTMLCanvasElement>("[data-hero-field]");
  const host = canvas?.closest("section") as HTMLElement | null;
  const ctx = canvas?.getContext("2d") ?? null;

  if (canvas && host && ctx) {
    const g = ctx;
    const cv = canvas;
    const hs = host;
    const reduce = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const INK = "11,23,38"; // --mp-ink
    const RED = "194,31,58"; // --mp-red
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const GRID = 60; // survey-grid spacing (CSS px)

    let w = 0;
    let h = 0;
    let raf = 0;
    let t0 = 0;
    let visible = true;
    // A datum station is pinned to a grid node; it pulses on a slow, staggered
    // cadence - the same measured accent the logo datum makes on hover.
    type Datum = { x: number; y: number; offset: number };
    let datums: Datum[] = [];
    const pointer = { x: 0, y: 0, active: false };

    const PERIOD = 5200; // ms between a station's registrations
    const PULSE = 1000; // ms the register accent lasts
    // logo easing, sampled 0..1 -> eased 0..1
    function ease(k: number) {
      // symmetric rise/fall so the datum returns to an identical rest square
      return Math.sin(Math.PI * Math.max(0, Math.min(1, k)));
    }

    function snap(v: number) {
      return Math.round(v / GRID) * GRID;
    }

    function seed() {
      // A few datum stations locked to interior grid nodes, spread across the
      // field and staggered in time so they never register in unison.
      const cols = Math.max(2, Math.floor(w / GRID));
      const rows = Math.max(2, Math.floor(h / GRID));
      const picks: Array<[number, number]> = [
        [0.24, 0.34],
        [0.7, 0.28],
        [0.52, 0.66],
        [0.86, 0.6],
      ];
      datums = picks.map(([fx, fy], i) => ({
        x: Math.max(1, Math.min(cols - 1, Math.round(fx * cols))) * GRID,
        y: Math.max(1, Math.min(rows - 1, Math.round(fy * rows))) * GRID,
        offset: (i * PERIOD) / picks.length,
      }));
    }

    function resize() {
      const r = hs.getBoundingClientRect();
      w = r.width;
      h = r.height;
      cv.width = Math.round(w * dpr);
      cv.height = Math.round(h * dpr);
      g.setTransform(dpr, 0, 0, dpr, 0, 0);
      seed();
    }

    // faint registered field: a small crosshair tick at every grid node
    function drawField() {
      g.strokeStyle = `rgba(${INK},0.05)`;
      g.lineWidth = 1;
      g.beginPath();
      for (let x = GRID; x < w; x += GRID) {
        for (let y = GRID; y < h; y += GRID) {
          g.moveTo(x - 3, y);
          g.lineTo(x + 3, y);
          g.moveTo(x, y - 3);
          g.lineTo(x, y + 3);
        }
      }
      g.stroke();
    }

    // a red datum square; when registering it rotates toward a diamond and
    // grows, then settles back to an axis-aligned square (its rest state)
    function drawDatum(d: Datum, t: number) {
      const local = (t - d.offset + PERIOD * 10) % PERIOD;
      const k = local < PULSE ? ease(local / PULSE) : 0;
      const s = 7 * (1 + 0.6 * k);
      const rot = (Math.PI / 4) * k; // up to 45deg (square -> diamond)
      const alpha = 0.5 + 0.4 * k;
      g.save();
      g.translate(d.x, d.y);
      g.rotate(rot);
      g.fillStyle = `rgba(${RED},${alpha})`;
      g.fillRect(-s / 2, -s / 2, s, s);
      g.restore();
    }

    function drawPointer() {
      if (!pointer.active) return;
      // snap the reticle to the nearest grid node - a precise datum lock
      const x = snap(pointer.x);
      const y = snap(pointer.y);
      g.strokeStyle = `rgba(${INK},0.26)`;
      g.lineWidth = 1;
      g.beginPath();
      g.moveTo(0, y + 0.5);
      g.lineTo(w, y + 0.5);
      g.moveTo(x + 0.5, 0);
      g.lineTo(x + 0.5, h);
      g.stroke();
      g.strokeStyle = `rgba(${RED},0.9)`;
      g.strokeRect(x - 4, y - 4, 8, 8);

      const label = `x ${Math.round(x)}  y ${Math.round(y)}`;
      g.font =
        "11px ui-monospace, SFMono-Regular, Menlo, Consolas, monospace";
      const tw = g.measureText(label).width;
      let lx = x + 12;
      let ly = y + 20;
      if (lx + tw + 8 > w) lx = x - tw - 16;
      if (ly + 8 > h) ly = y - 12;
      g.fillStyle = `rgba(${INK},0.92)`;
      g.fillRect(lx - 5, ly - 12, tw + 10, 17);
      g.fillStyle = "rgba(247,245,240,0.96)";
      g.fillText(label, lx, ly);
    }

    function render(t: number) {
      g.clearRect(0, 0, w, h);
      drawField();
      for (const d of datums) drawDatum(d, t);
      drawPointer();
    }

    function tick(ts: number) {
      if (!t0) t0 = ts;
      render(ts - t0);
      raf = requestAnimationFrame(tick);
    }

    function play() {
      if (reduce) {
        render(0);
        return;
      }
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(tick);
    }
    function pause() {
      cancelAnimationFrame(raf);
    }

    hs.addEventListener("pointermove", (e) => {
      if (e.pointerType === "touch") return;
      const r = hs.getBoundingClientRect();
      pointer.x = e.clientX - r.left;
      pointer.y = e.clientY - r.top;
      pointer.active = true;
      if (reduce) render(0);
    });
    hs.addEventListener("pointerleave", () => {
      pointer.active = false;
      if (reduce) render(0);
    });

    new ResizeObserver(() => {
      resize();
      if (reduce || !visible) render(0);
    }).observe(hs);

    new IntersectionObserver(
      ([entry]) => {
        visible = entry.isIntersecting;
        if (!reduce) (visible ? play : pause)();
      },
      { threshold: 0 },
    ).observe(hs);

    resize();
    play();
  }
</script>

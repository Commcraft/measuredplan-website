---
// Mono technical label with an optional red datum tick.
interface Props {
  tick?: boolean;
  class?: string;
}
const { tick = true, class: className = "" } = Astro.props;
---

<p class:list={["eyebrow flex items-center gap-2.5", className]}>
  {tick && <span class="eyebrow-rule" aria-hidden="true"></span>}
  <slot />
</p>

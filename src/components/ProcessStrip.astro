---
// Numbered four-step process. Horizontal on desktop, stacked on mobile.
interface Step {
  title: string;
  body: string;
}
interface Props {
  steps: Step[];
  class?: string;
}
const { steps, class: className = "" } = Astro.props;
---

<ol
  class:list={[
    "grid gap-px overflow-hidden border border-line bg-line sm:grid-cols-2 lg:grid-cols-4",
    className,
  ]}
>
  {
    steps.map((step, i) => (
      <li class="flex flex-col bg-white p-6 lg:p-7">
        <div class="flex items-center gap-3">
          <span class="font-mono text-sm text-ink-muted">
            {String(i + 1).padStart(2, "0")}
          </span>
          <span
            class="h-px flex-1 bg-line"
            aria-hidden="true"
          />
          {i === steps.length - 1 && (
            <span class="datum-tick" aria-hidden="true" />
          )}
        </div>
        <h3 class="mt-5 text-lg leading-snug">{step.title}</h3>
        <p class="mt-2 text-sm leading-relaxed text-ink-muted">{step.body}</p>
      </li>
    ))
  }
</ol>

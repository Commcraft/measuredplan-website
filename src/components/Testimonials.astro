---
// Client testimonials grid. Attributions are anonymized by client type -
// no personal names or company names are shown.
interface Item {
  quote: string;
  name: string;
  role: string;
  company: string;
}
interface Props {
  items: Item[];
}
const { items } = Astro.props;
---

<div class="mt-14 grid gap-x-10 gap-y-12 md:grid-cols-3 md:gap-x-12">
  {
    items.map((t) => (
      <figure class="flex h-full flex-col border-t border-line pt-6">
        <span class="datum-tick mb-5" aria-hidden="true" />
        <blockquote class="flex-1 text-[1.15rem] leading-relaxed text-ink">
          <p>{t.quote}</p>
        </blockquote>
        <figcaption class="mt-6">
          <p class="font-medium text-ink">{t.name}</p>
          <p class="mt-1 font-mono text-xs text-ink-muted">
            {t.role} · {t.company}
          </p>
        </figcaption>
      </figure>
    ))
  }
</div>

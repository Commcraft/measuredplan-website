---
// Shared conversion band - the single dark band pattern (besides the footer).
import { getCollection } from "astro:content";

import Container from "./Container.astro";
import Eyebrow from "./Eyebrow.astro";
import LinkButton from "./LinkButton.astro";
import { PRIMARY_CTA } from "../consts";

interface Props {
  eyebrow?: string;
  title?: string;
  body?: string;
  ctaLabel?: string;
  ctaHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  /** Show a short client quote beside the CTA (social proof at the action). */
  proof?: boolean;
}
const {
  eyebrow = "Start a project",
  title = "Tell us about your property and what the drawings are for.",
  body = "Send the address, floor area or stories, and your deadline. We'll confirm scope, format and a clear price - usually within one business day.",
  ctaLabel = PRIMARY_CTA.label,
  ctaHref = PRIMARY_CTA.href,
  secondaryLabel,
  secondaryHref,
  proof = true,
} = Astro.props;
const hasDot = /\.\s*$/.test(title);
const titleMain = hasDot ? title.replace(/\.\s*$/, "") : title;

// One short client quote, placed right beside the action. Evidence: social
// proof adjacent to a CTA lifts conversion. Kept factual from the collection.
const testimonials = proof
  ? (await getCollection("testimonials")).sort(
      (a, b) => a.data.order - b.data.order,
    )
  : [];
const quote = testimonials[0]?.data;
---

<section class="band-ink relative overflow-hidden">
  <div class="cad-grid absolute inset-0 opacity-[0.05]" aria-hidden="true"></div>
  <Container class="relative py-16 sm:py-20 lg:py-24">
    <div class="grid gap-10 lg:grid-cols-[1.4fr_1fr] lg:items-end">
      <div>
        <Eyebrow class="mb-5">{eyebrow}</Eyebrow>
        <h2 class="max-w-2xl text-[1.8rem] leading-tight sm:text-4xl">
          {titleMain}{hasDot && <span class="title-dot" aria-hidden="true" />}
        </h2>
        {
          body && (
            <p class="mt-5 max-w-xl text-base leading-relaxed text-ink-muted-inverse">
              {body}
            </p>
          )
        }
        {
          quote && (
            <figure class="mt-8 max-w-xl border-l-2 border-red pl-5">
              <blockquote class="text-[0.95rem] leading-relaxed text-paper">
                &ldquo;{quote.quote}&rdquo;
              </blockquote>
              <figcaption class="mt-2.5 font-mono text-xs uppercase tracking-wider text-ink-muted-inverse">
                {quote.name} - {quote.company}
              </figcaption>
            </figure>
          )
        }
      </div>
      <div class="flex flex-wrap gap-3 lg:justify-end">
        <LinkButton href={ctaHref} variant="primary" size="lg">{ctaLabel}</LinkButton>
        {
          secondaryLabel && secondaryHref && (
            <LinkButton href={secondaryHref} variant="outline" size="lg">
              {secondaryLabel}
            </LinkButton>
          )
        }
      </div>
    </div>
  </Container>
</section>

---
import Container from "./Container.astro";
import Logo from "./Logo.astro";
import WhatsAppLink from "./WhatsAppLink.astro";
import {
  BUSINESS,
  FOOTER_SERVICES,
  FOOTER_COMPANY,
  FOOTER_LEGAL,
  SITE_TAGLINE,
} from "../consts";

const year = 2026; // build-time constant; update at release
---

<footer class="band-ink">
  <Container class="py-16 lg:py-20">
    <div class="grid gap-12 lg:grid-cols-[1.4fr_1fr_1fr_1.1fr]">
      <div class="max-w-xs">
        <Logo tone="paper" img />
        <p class="mt-5 text-[0.95rem] leading-relaxed text-ink-muted-inverse">
          {SITE_TAGLINE}. Precise as-built drawings and design documentation for architects,
          property owners and attorneys.
        </p>
        <p class="mt-4 font-mono text-sm text-ink-muted-inverse">
          Formats: {BUSINESS.formats.join(" · ")}
        </p>
      </div>

      <nav aria-label="Services">
        <h2 class="eyebrow mb-4">Services</h2>
        <ul class="space-y-2.5">
          {
            FOOTER_SERVICES.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-[0.95rem] text-ink-muted-inverse transition-colors hover:text-paper"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <nav aria-label="Company">
        <h2 class="eyebrow mb-4">Practice</h2>
        <ul class="space-y-2.5">
          {
            FOOTER_COMPANY.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-[0.95rem] text-ink-muted-inverse transition-colors hover:text-paper"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div>
        <h2 class="eyebrow mb-4">Contact</h2>
        <ul class="space-y-2.5 text-[0.95rem] text-ink-muted-inverse">
          <li>
            <a
              href={`mailto:${BUSINESS.email}`}
              class="transition-colors hover:text-paper">{BUSINESS.email}</a
            >
          </li>
          <li>
            <a
              href={`tel:${BUSINESS.phoneHref}`}
              class="transition-colors hover:text-paper">{BUSINESS.phone}</a
            >
          </li>
          <li>
            <WhatsAppLink variant="footer" />
          </li>
          <li class="pt-1">{BUSINESS.hours}</li>
          <li class="text-ink-muted-inverse">{BUSINESS.areaServed}</li>
        </ul>
      </div>
    </div>

    <div
      class="mt-14 flex flex-col gap-4 border-t border-line-inverse pt-8 text-sm text-ink-muted-inverse sm:flex-row sm:items-center sm:justify-between"
    >
      <p class="font-mono">
        © {year} {BUSINESS.name} · {BUSINESS.location}
      </p>
      <ul class="flex items-center gap-6">
        {
          FOOTER_LEGAL.map((link) => (
            <li>
              <a
                href={link.href}
                class="transition-colors hover:text-paper"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </Container>
</footer>

---
// Interior-page header: breadcrumb + eyebrow + H1 + intro.
import Breadcrumbs from "./Breadcrumbs.astro";
import Container from "./Container.astro";
import Eyebrow from "./Eyebrow.astro";

interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  crumbs?: Crumb[];
  surface?: "paper" | "cad" | "stone";
}
const { eyebrow, title, intro, crumbs = [], surface = "paper" } = Astro.props;
const hasDot = /\.\s*$/.test(title);
const titleMain = hasDot ? title.replace(/\.\s*$/, "") : title;
const bg =
  surface === "cad" ? "surface-cad" : surface === "stone" ? "surface-stone" : "bg-paper";
---

<section class:list={[bg, "border-b border-line pt-12 pb-14 sm:pt-16 sm:pb-16"]}>
  <Container data-reveal>
    {crumbs.length > 0 && <Breadcrumbs items={crumbs} class="mb-8" />}
    {eyebrow && <Eyebrow class="mb-5">{eyebrow}</Eyebrow>}
    <h1 class="max-w-4xl text-[2.1rem] leading-[1.08] sm:text-5xl lg:text-[3.4rem]">
      {titleMain}{hasDot && <span class="title-dot" aria-hidden="true" />}
    </h1>
    {
      intro && (
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ink-muted">
          {intro}
        </p>
      )
    }
    <slot />
  </Container>
</section>

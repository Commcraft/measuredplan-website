---
// Core & extended service area. The tier structure and Asheville / Western
// North Carolina framing come from confirmed business facts; town names are
// illustrative examples of each tier ("such as"), easy to edit in the arrays
// below. The left panel is a real map (Leaflet + CARTO light basemap, self-
// hosted) centred on Asheville, with branded core/extended coverage rings.
import Eyebrow from "./Eyebrow.astro";

const core = [
  "Asheville",
  "Black Mountain",
  "Weaverville",
  "Fletcher",
  "Arden",
  "Fairview",
  "Swannanoa",
  "Candler",
];
const extended = [
  "Hendersonville",
  "Waynesville",
  "Brevard",
  "Marion",
  "Burnsville",
  "Sylva",
  "Marshall",
  "Lake Lure",
];
---

<link rel="stylesheet" href="/vendor/leaflet/leaflet.css" />

<div class="grid items-center gap-12 lg:grid-cols-[1.05fr_0.95fr] lg:gap-16">
  <!-- Real coverage map -->
  <div>
    <div class="title-block overflow-hidden">
      <div
        id="sa-map"
        class="h-[340px] w-full bg-cad sm:h-[420px]"
        role="img"
        aria-label="Map of MeasuredPlan's service area, centred on Asheville and covering Western North Carolina."
      >
        <!-- No-JS / pre-load fallback (removed when the map initializes) -->
        <div
          data-sa-fallback
          class="flex h-full w-full flex-col items-center justify-center gap-2 p-6 text-center"
        >
          <span class="datum-tick" aria-hidden="true"></span>
          <p class="font-mono text-xs text-ink-muted">
            Asheville · Western North Carolina
          </p>
        </div>
      </div>
    </div>
    <div class="mt-4 flex flex-wrap justify-center gap-6 font-mono text-xs text-ink-muted">
      <span class="flex items-center gap-2">
        <span class="h-2.5 w-2.5 bg-red" aria-hidden="true"></span>Core area
      </span>
      <span class="flex items-center gap-2">
        <span
          class="h-2.5 w-2.5 border border-dashed border-line-strong"
          aria-hidden="true"></span>Extended area
      </span>
    </div>
  </div>

  <!-- Tiers -->
  <div>
    <div class="border-l-2 border-red pl-5">
      <Eyebrow class="mb-2">Core service area</Eyebrow>
      <p class="text-[1.05rem] leading-relaxed text-ink">
        Asheville and Greater Asheville - on-site measured work at standard
        scheduling, with no out-of-town travel premium.
      </p>
      <p class="mt-3 font-mono text-xs leading-relaxed text-ink-muted">
        {core.join("  ·  ")}
      </p>
    </div>

    <div class="mt-8 border-l-2 border-line-strong pl-5">
      <Eyebrow class="mb-2">Extended service area</Eyebrow>
      <p class="text-[1.05rem] leading-relaxed text-ink">
        Across Western North Carolina - towns such as those below, with any
        travel included in the fixed quote.
      </p>
      <p class="mt-3 font-mono text-xs leading-relaxed text-ink-muted">
        {extended.join("  ·  ")}
      </p>
    </div>

    <p class="mt-8 text-sm text-ink-muted">
      Outside Western North Carolina? We take on select projects further afield
      by arrangement - <a
        href="/contact/"
        class="text-ink underline underline-offset-4">ask about your location</a
      >.
    </p>
  </div>
</div>

<script is:inline>
  (function () {
    var el = document.getElementById("sa-map");
    if (!el) return;
    var started = false;

    function loadLeaflet(cb) {
      if (window.L) return cb();
      var s = document.createElement("script");
      s.src = "/vendor/leaflet/leaflet.js";
      s.onload = cb;
      document.head.appendChild(s);
    }

    function init() {
      if (started) return;
      started = true;
      loadLeaflet(function () {
        var L = window.L;
        var fallback = el.querySelector("[data-sa-fallback]");
        if (fallback) fallback.remove();
        var asheville = [35.5951, -82.5515];
        var map = L.map(el, {
          scrollWheelZoom: false,
          attributionControl: true,
          zoomControl: true,
        }).setView(asheville, 8);
        L.tileLayer(
          "https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png",
          {
            attribution:
              '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/attributions">CARTO</a>',
            subdomains: "abcd",
            maxZoom: 19,
          },
        ).addTo(map);
        // Extended coverage (Western North Carolina)
        L.circle(asheville, {
          radius: 120000,
          color: "#0B1726",
          weight: 1,
          opacity: 0.4,
          dashArray: "3 6",
          fillColor: "#0B1726",
          fillOpacity: 0.03,
        }).addTo(map);
        // Core coverage (Greater Asheville)
        L.circle(asheville, {
          radius: 45000,
          color: "#C21F3A",
          weight: 1.5,
          opacity: 0.85,
          fillColor: "#C21F3A",
          fillOpacity: 0.06,
        }).addTo(map);
        // Asheville datum marker
        var icon = L.divIcon({
          className: "sa-datum",
          html: '<span style="display:block;width:14px;height:14px;background:#C21F3A;box-shadow:0 0 0 3px rgba(247,245,240,.95)"></span>',
          iconSize: [14, 14],
          iconAnchor: [7, 7],
        });
        L.marker(asheville, { icon: icon })
          .addTo(map)
          .bindTooltip("Asheville", {
            permanent: true,
            direction: "right",
            offset: [10, 0],
            className: "sa-tip",
          });
      });
    }

    if ("IntersectionObserver" in window) {
      var io = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              init();
              io.disconnect();
            }
          });
        },
        { rootMargin: "250px" },
      );
      io.observe(el);
    } else {
      init();
    }
  })();
</script>
